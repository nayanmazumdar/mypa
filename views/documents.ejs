<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Document Vault – MyPA</title>
  <link rel="icon" type="image/png" href="/logo.png">
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <%- include('partials/navbar') %>
  <div class="container">
    <div class="page-header">
      <h1>🔐 Document Vault</h1>
      <p>Securely store your identity documents — private and accessible only by you</p>
    </div>

    <% if (success) { %><div class="alert alert-success">✅ <%= success %></div><% } %>
    <% if (error) { %><div class="alert alert-danger">⚠️ <%= error %></div><% } %>

    <div class="grid grid-2">
      <!-- Upload -->
      <div class="card">
        <div class="card-header"><h2>📤 Upload Document</h2></div>
        <div class="card-body">
          <form action="/documents/upload" method="POST" enctype="multipart/form-data">
            <div class="form-group">
              <label class="form-label">Document Type <span class="required">*</span></label>
              <select class="form-control" name="document_type" required>
                <option value="">Select type</option>
                <option value="aadhaar">Aadhaar Card</option>
                <option value="pan">PAN Card</option>
                <option value="trade_license">Trade License</option>
                <option value="gst_certificate">GST Certificate</option>
                <option value="other">Other Document</option>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label">Select File <span class="required">*</span></label>
              <input type="file" class="form-control" name="document" required accept="image/jpeg,image/png,image/webp,application/pdf">
              <p class="form-hint">JPG, PNG, WEBP, PDF · Max 5 MB</p>
            </div>
            <button type="submit" class="btn btn-primary btn-block">🔒 Upload Securely</button>
          </form>

          <div class="alert alert-info" style="margin-top:1.5rem;">
            <div>
              <strong>🛡️ Security</strong><br>
              <span style="font-size:.82rem;">Documents are stored privately and accessible only by you. No other user can view your documents.</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Documents list -->
      <div class="card">
        <div class="card-header">
          <h2>📁 Your Documents</h2>
          <span class="badge badge-purple"><%= docs.length %> file<%= docs.length !== 1 ? 's' : '' %></span>
        </div>
        <div class="card-body">
          <% if (docs.length === 0) { %>
            <div style="text-align:center;padding:2rem;">
              <div style="font-size:2.5rem;margin-bottom:.75rem;">📂</div>
              <p class="text-muted">No documents uploaded yet.</p>
            </div>
          <% } else { %>
            <% const icons = {aadhaar:'🪪',pan:'💳',trade_license:'📜',gst_certificate:'🏛️',other:'📄'}; %>
            <% docs.forEach(d => { %>
            <div style="display:flex;align-items:center;justify-content:space-between;padding:.75rem 0;border-bottom:1px solid var(--gray-100);">
              <div style="display:flex;align-items:center;gap:.75rem;">
                <div style="font-size:1.8rem;"><%= icons[d.document_type] || '📄' %></div>
                <div>
                  <div class="fw-bold text-sm"><%= d.file_name %></div>
                  <div class="text-muted" style="font-size:.78rem;text-transform:capitalize;"><%= d.document_type.replace(/_/g,' ') %> · <%= new Date(d.uploaded_at).toLocaleDateString('en-IN') %></div>
                </div>
              </div>
              <div style="display:flex;gap:.5rem;">
                <a href="<%= d.file_path %>" target="_blank" class="btn btn-sm btn-outline">View</a>
                <a href="/documents/delete/<%= d.document_id %>" class="btn btn-sm btn-danger" onclick="return confirm('Delete this document permanently?')">🗑️</a>
              </div>
            </div>
            <% }) %>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
