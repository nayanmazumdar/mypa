<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Shop QR Code – MyPA</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <%- include('partials/navbar') %>
  <div class="container" style="max-width:600px;">
    <div class="page-header">
      <h1>📱 Shop QR Code</h1>
      <p>Customers scan this to self-register for credit at your shop</p>
    </div>

    <div class="card" style="margin-bottom:1.5rem;">
      <div class="card-body qr-wrap">
        <div style="text-align:center;margin-bottom:1rem;">
          <% if (business.business_logo) { %>
            <img src="<%= business.business_logo %>" width="60" height="60" style="border-radius:10px;margin-bottom:.5rem;">
          <% } %>
          <h2 style="font-size:1.3rem;font-weight:700;"><%= business.business_name %></h2>
          <p class="text-muted text-sm"><%= business.business_type %></p>
        </div>

        <img src="<%= qrDataUrl %>" width="260" height="260" alt="Shop QR" style="border:8px solid var(--gray-100);border-radius:16px;">

        <div class="alert alert-info" style="margin-top:1.5rem;width:100%;">
          <div>
            <strong>How it works:</strong><br>
            <span style="font-size:.85rem;">Customer scans → opens registration form → enters name & mobile → automatically added to your customer list ✅</span>
          </div>
        </div>

        <div style="display:flex;gap:.75rem;flex-wrap:wrap;justify-content:center;">
          <a href="<%= qrDataUrl %>" download="<%= business.business_name %>-QR.png" class="btn btn-primary">⬇️ Download PNG</a>
          <button onclick="window.print()" class="btn btn-secondary">🖨️ Print QR</button>
        </div>

        <div style="margin-top:1.5rem;padding:1rem;background:var(--gray-50);border-radius:8px;width:100%;">
          <p class="text-sm text-muted" style="margin-bottom:.35rem;">Registration URL:</p>
          <code style="font-size:.8rem;word-break:break-all;color:var(--primary);"><%= url %></code>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="card-header"><h2>📋 Instructions for Display</h2></div>
      <div class="card-body">
        <ol style="list-style:decimal;padding-left:1.25rem;font-size:.9rem;line-height:2;">
          <li>Download the QR code image above</li>
          <li>Print and laminate it</li>
          <li>Display it at your shop counter</li>
          <li>Tell customers: <em>"Scan to register for credit purchases"</em></li>
          <li>New customers appear instantly in your <a href="/customers" style="color:var(--primary);">Customers list</a></li>
        </ol>
      </div>
    </div>
  </div>

  <style>
    @media print {
      .navbar, .card:last-child, .page-header p, h1 + * + * { display: none; }
    }
  </style>
</body>
</html>
