<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Account – <%= business ? business.business_name : 'MyPA' %></title>
  <link rel="icon" type="image/png" href="/logo.png">
  <link rel="stylesheet" href="/style.css">
  <style>
    .portal-header{background:linear-gradient(135deg,var(--primary),var(--primary-dark));color:#fff;border-radius:14px;padding:1.5rem;margin-bottom:1.5rem;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem;}
    .portal-header h1{font-size:1.3rem;font-weight:800;margin-bottom:.25rem;}
    .portal-header p{font-size:.85rem;opacity:.85;}
    .ledger-table{width:100%;border-collapse:collapse;font-size:.875rem;}
    .ledger-table th{background:var(--gray-50);padding:.6rem .75rem;text-align:left;font-weight:600;border-bottom:2px solid var(--gray-200);}
    .ledger-table td{padding:.6rem .75rem;border-bottom:1px solid var(--gray-100);vertical-align:middle;}
    .tag{display:inline-block;padding:.2rem .55rem;border-radius:20px;font-size:.72rem;font-weight:700;white-space:nowrap;}
    .tag-c{background:#fff3f3;color:var(--danger);}
    .tag-p{background:#f0fdf4;color:var(--success);}
    .hidden{display:none!important;}
  </style>
</head>
<body>
  <nav class="navbar">
    <div class="navbar-inner">
      <a href="/customer-portal" class="navbar-brand">
        <img src="/logo.png" style="height:38px;width:38px;border-radius:50%;object-fit:cover;">
        <span style="font-size:1.2rem;font-weight:800;">MyPA</span>
      </a>
      <div class="navbar-nav">
        <span class="nav-link" style="color:rgba(255,255,255,.7);font-size:.85rem;">👤 <%= customer.name %></span>
        <a href="/customer-logout" class="nav-link" style="color:#fca5a5;">🚪 Logout</a>
      </div>
    </div>
  </nav>

  <div class="container">

    <!-- Portal header -->
    <div class="portal-header">
      <div>
        <h1>👋 Hello, <%= customer.name %></h1>
        <p><% if(business){ %><%= business.business_name %><% } %> · 📞 <%= customer.mobile %></p>
      </div>
      <div style="text-align:right;">
        <div style="font-size:.75rem;opacity:.75;">Outstanding Balance</div>
        <div style="font-size:1.75rem;font-weight:800;">₹<%= outstanding.toLocaleString('en-IN') %></div>
      </div>
    </div>

    <!-- Summary -->
    <div class="grid grid-3" style="margin-bottom:1.5rem;">
      <div class="stat-card"><div class="stat-icon amber">🛒</div><div class="stat-info"><p>Total Credit</p><h3>₹<%= totalCredit.toLocaleString('en-IN') %></h3></div></div>
      <div class="stat-card"><div class="stat-icon green">💰</div><div class="stat-info"><p>Total Paid</p><h3>₹<%= totalReceived.toLocaleString('en-IN') %></h3></div></div>
      <div class="stat-card"><div class="stat-icon indigo">📊</div><div class="stat-info"><p>Balance Due</p><h3>₹<%= outstanding.toLocaleString('en-IN') %></h3></div></div>
    </div>

    <!-- Filter + Print -->
    <div class="card" style="margin-bottom:1rem;">
      <div class="card-body" style="padding:.875rem 1.25rem;">
        <form method="GET" action="/customer-portal" style="display:flex;gap:.75rem;align-items:flex-end;flex-wrap:wrap;">
          <div class="form-group" style="margin-bottom:0;flex:1;min-width:140px;">
            <label class="form-label">From Date</label>
            <input type="date" class="form-control" name="from" value="<%= from %>">
          </div>
          <div class="form-group" style="margin-bottom:0;flex:1;min-width:140px;">
            <label class="form-label">To Date</label>
            <input type="date" class="form-control" name="to" value="<%= to %>">
          </div>
          <button type="submit" class="btn btn-primary">🔍 Filter</button>
          <a href="/customer-portal" class="btn btn-secondary">Clear</a>
          <button type="button" class="btn btn-secondary" onclick="document.getElementById('printPanel').classList.toggle('hidden')">📄 Print Report</button>
        </form>
      </div>
    </div>

    <!-- Print panel -->
    <div id="printPanel" class="hidden card" style="margin-bottom:1rem;background:#f0f4ff;border:1px solid #c7d6ff;">
      <div class="card-body" style="padding:.875rem 1.25rem;">
        <form action="/customer-portal/report" method="GET" target="_blank"
              style="display:flex;gap:.75rem;align-items:flex-end;flex-wrap:wrap;">
          <div class="form-group" style="margin-bottom:0;">
            <label class="form-label" style="font-size:.8rem;">From Date</label>
            <input type="date" class="form-control" name="from" value="<%= from %>" style="padding:.4rem .75rem;">
          </div>
          <div class="form-group" style="margin-bottom:0;">
            <label class="form-label" style="font-size:.8rem;">To Date</label>
            <input type="date" class="form-control" name="to" value="<%= to||new Date().toISOString().slice(0,10) %>" style="padding:.4rem .75rem;">
          </div>
          <button type="submit" class="btn btn-primary" style="padding:.45rem 1.25rem;">🖨️ Generate & Print</button>
          <button type="button" class="btn btn-secondary" onclick="document.getElementById('printPanel').classList.add('hidden')" style="padding:.45rem 1rem;">Cancel</button>
        </form>
      </div>
    </div>

    <!-- Ledger -->
    <div class="card">
      <div class="card-header">
        <h2>📒 My Transactions</h2>
        <span class="badge badge-navy"><%= transactions.length %> records</span>
      </div>
      <% if (transactions.length === 0) { %>
        <div class="card-body text-center" style="padding:3rem;">
          <div style="font-size:3rem;margin-bottom:.75rem;">📋</div>
          <p class="text-muted">No transactions found for the selected period.</p>
        </div>
      <% } else { %>
      <div style="overflow-x:auto;">
        <table class="ledger-table">
          <thead>
            <tr><th>#</th><th>Date</th><th>Type</th><th>Amount</th><th>Note</th><th>Bill</th><th style="text-align:right;">Balance</th></tr>
          </thead>
          <tbody>
            <% transactions.forEach(function(t, i) { %>
            <tr>
              <td class="text-muted text-sm"><%= i+1 %></td>
              <td style="white-space:nowrap;"><%= new Date(t.date).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) %></td>
              <td>
                <% if(t.type==='sale_credit'||t.type==='sale'){ %>
                  <span class="tag tag-c">🛒 Sale/Credit</span>
                <% }else{ %>
                  <span class="tag tag-p">💰 Payment</span>
                <% } %>
              </td>
              <td style="font-weight:600;color:<%= (t.type==='sale_credit'||t.type==='sale')?'var(--danger)':'var(--success)' %>;">
                <%= (t.type==='payment_cash'||t.type==='payment')?'-':'+' %>₹<%= t.amount.toLocaleString('en-IN') %>
              </td>
              <td class="text-muted text-sm"><%= t.note||'—' %></td>
              <td>
                <% if(t.bill_photo){ %>
                  <a href="<%= t.bill_photo %>" target="_blank" style="color:var(--primary);font-size:.8rem;font-weight:600;padding:.2rem .5rem;background:#eff6ff;border-radius:6px;border:1px solid #bfdbfe;text-decoration:none;">🧾 View</a>
                <% }else{ %>
                  <span class="text-muted text-sm">—</span>
                <% } %>
              </td>
              <td style="text-align:right;font-weight:700;color:<%= t.running>0?'var(--danger)':'var(--success)' %>;">
                ₹<%= t.running.toLocaleString('en-IN') %>
              </td>
            </tr>
            <% }) %>
          </tbody>
          <tfoot>
            <tr style="background:var(--gray-50);">
              <td colspan="6" style="font-weight:800;padding:.75rem;">Outstanding Balance</td>
              <td style="text-align:right;font-weight:800;color:<%= outstanding>0?'var(--danger)':'var(--success)' %>;padding:.75rem;">₹<%= outstanding.toLocaleString('en-IN') %></td>
            </tr>
          </tfoot>
        </table>
      </div>
      <% } %>
    </div>

  </div>
</body>
</html>
