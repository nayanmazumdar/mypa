<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Transaction Report – <%= customer.name %></title>
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    body { font-family:'Segoe UI',Arial,sans-serif; font-size:13px; color:#111; background:#fff; }

    .screen-only {
      background:#f1f5f9; padding:.875rem 2rem; display:flex;
      align-items:center; gap:1rem; flex-wrap:wrap;
      border-bottom:2px solid #e2e8f0; position:sticky; top:0; z-index:10;
    }
    .screen-only h2 { font-size:1rem; color:#1e3a8a; flex:1; }
    .btn-print { background:#1e3a8a; color:#fff; border:none; padding:.5rem 1.4rem; border-radius:7px; font-size:.875rem; font-weight:700; cursor:pointer; }
    .btn-print:hover { background:#2d4fb5; }
    .btn-back { background:#fff; color:#1e3a8a; border:1.5px solid #1e3a8a; padding:.5rem 1.2rem; border-radius:7px; font-size:.875rem; font-weight:600; cursor:pointer; text-decoration:none; display:inline-block; }

    .report { max-width:860px; margin:1.5rem auto; padding:2rem; background:#fff; }

    .report-header { display:flex; justify-content:space-between; align-items:flex-start; padding-bottom:1rem; border-bottom:3px solid #1e3a8a; margin-bottom:1.25rem; }
    .biz-name { font-size:1.35rem; font-weight:800; color:#1e3a8a; }
    .biz-meta { font-size:.8rem; color:#475569; margin-top:.3rem; line-height:1.7; }
    .report-title { text-align:right; }
    .report-title h1 { font-size:1.05rem; font-weight:800; color:#1e3a8a; text-transform:uppercase; letter-spacing:.05em; }
    .report-title p  { font-size:.78rem; color:#64748b; margin-top:.25rem; }

    .customer-box { background:#f8fafc; border:1px solid #e2e8f0; border-radius:8px; padding:.875rem 1.25rem; margin-bottom:1.25rem; display:grid; grid-template-columns:1fr 1fr; gap:.5rem 1rem; }
    .lbl { font-size:.7rem; font-weight:700; text-transform:uppercase; color:#94a3b8; letter-spacing:.04em; }
    .val { font-size:.875rem; font-weight:600; color:#1e293b; margin-top:.1rem; }

    .date-banner { background:#1e3a8a; color:#fff; border-radius:7px; padding:.6rem 1.1rem; margin-bottom:1.25rem; display:flex; justify-content:space-between; align-items:center; font-size:.82rem; }
    .date-banner strong { font-size:.95rem; }

    .summary-row { display:grid; grid-template-columns:1fr 1fr 1fr; gap:.75rem; margin-bottom:1.25rem; }
    .tile { border:1px solid #e2e8f0; border-radius:8px; padding:.75rem 1rem; text-align:center; }
    .tile .t-lbl { font-size:.7rem; font-weight:700; text-transform:uppercase; color:#94a3b8; letter-spacing:.04em; }
    .tile .t-val { font-size:1.2rem; font-weight:800; margin-top:.25rem; }

    .section-title { font-size:.82rem; font-weight:700; color:#1e3a8a; text-transform:uppercase; letter-spacing:.05em; margin-bottom:.5rem; padding-bottom:.4rem; border-bottom:2px solid #e2e8f0; }

    table { width:100%; border-collapse:collapse; font-size:.82rem; }
    thead tr { background:#1e3a8a; color:#fff; }
    thead th { padding:.55rem .75rem; text-align:left; font-weight:700; }
    thead th.r { text-align:right; }
    tbody tr:nth-child(even) { background:#f8fafc; }
    tbody td { padding:.5rem .75rem; border-bottom:1px solid #f1f5f9; vertical-align:middle; }
    tbody td.r { text-align:right; font-weight:700; }
    tfoot tr { background:#dbeafe; }
    tfoot td { padding:.65rem .75rem; font-weight:800; font-size:.85rem; }
    tfoot td.r { text-align:right; font-size:.95rem; }

    .tag-c { display:inline-block; padding:.15rem .55rem; background:#fee2e2; color:#dc2626; border-radius:12px; font-size:.7rem; font-weight:700; }
    .tag-p { display:inline-block; padding:.15rem .55rem; background:#dcfce7; color:#16a34a; border-radius:12px; font-size:.7rem; font-weight:700; }

    .no-data { text-align:center; padding:3rem; color:#94a3b8; }

    .sig-block { display:grid; grid-template-columns:1fr 1fr; gap:3rem; margin-top:3rem; }
    .sig-line  { border-top:1px solid #94a3b8; padding-top:.4rem; font-size:.72rem; color:#64748b; text-align:center; }

    .report-footer { margin-top:1.5rem; padding-top:.75rem; border-top:1px solid #e2e8f0; display:flex; justify-content:space-between; font-size:.7rem; color:#94a3b8; }

    @media print {
      .screen-only { display:none !important; }
      body { font-size:12px; }
      .report { margin:0; padding:1cm; max-width:100%; }
      @page { size:A4; margin:1.5cm; }
    }
  </style>
</head>
<body>

  <!-- Screen controls -->
  <div class="screen-only">
    <h2>📄 Transaction Report — <%= customer.name %></h2>
    <a href="/customers/<%= customer.customer_id %>" class="btn-back">← Back</a>
    <button class="btn-print" onclick="window.print()">🖨️ Print / Save as PDF</button>
  </div>

  <div class="report">

    <!-- Header -->
    <div class="report-header">
      <div>
        <% if (business && business.business_logo) { %>
          <img src="<%= business.business_logo %>" height="40" style="margin-bottom:.4rem;display:block;">
        <% } %>
        <div class="biz-name"><%= business ? business.business_name : 'MyPA' %></div>
        <div class="biz-meta">
          <% if (business && business.address)    { %><%= business.address %><br><% } %>
          <% if (business && business.gst_number) { %>GST: <%= business.gst_number %><br><% } %>
          <% if (user.mobile) { %>📞 <%= user.mobile %><% } %>
        </div>
      </div>
      <div class="report-title">
        <h1>Customer Statement</h1>
        <p>Generated: <%= new Date().toLocaleDateString('en-IN',{day:'numeric',month:'long',year:'numeric'}) %></p>
        <p style="margin-top:.2rem;font-family:monospace;font-size:.7rem;color:#94a3b8;"><%= customer.customer_id %></p>
      </div>
    </div>

    <!-- Customer info -->
    <div class="customer-box">
      <div><div class="lbl">Customer Name</div><div class="val"><%= customer.name %></div></div>
      <div><div class="lbl">Mobile</div><div class="val"><%= customer.mobile %></div></div>
      <% if (customer.address) { %>
      <div><div class="lbl">Address</div><div class="val"><%= customer.address %></div></div>
      <% } %>
      <% if (customer.occupation) { %>
      <div><div class="lbl">Occupation</div><div class="val"><%= customer.occupation %></div></div>
      <% } %>
      <div><div class="lbl">Credit Limit</div><div class="val">₹<%= (customer.credit_limit||0).toLocaleString('en-IN') %></div></div>
      <div><div class="lbl">Status</div><div class="val" style="text-transform:capitalize;"><%= customer.status %></div></div>
    </div>

    <!-- Date range -->
    <div class="date-banner">
      <span>📅 Statement Period</span>
      <strong>
        <%= from ? new Date(from).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) : 'All time' %>
        &nbsp;→&nbsp;
        <%= to   ? new Date(to).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'})   : 'Today' %>
      </strong>
      <span><%= transactions.length %> transaction<%= transactions.length !== 1 ? 's' : '' %></span>
    </div>

    <!-- Summary -->
    <div class="summary-row">
      <div class="tile">
        <div class="t-lbl">Total Credit Given</div>
        <div class="t-val" style="color:#dc2626;">₹<%= totalCredit.toLocaleString('en-IN') %></div>
      </div>
      <div class="tile">
        <div class="t-lbl">Total Cash Received</div>
        <div class="t-val" style="color:#16a34a;">₹<%= totalReceived.toLocaleString('en-IN') %></div>
      </div>
      <div class="tile">
        <div class="t-lbl">Outstanding Balance</div>
        <div class="t-val" style="color:<%= outstanding > 0 ? '#dc2626' : '#16a34a' %>;">
          ₹<%= outstanding.toLocaleString('en-IN') %>
        </div>
      </div>
    </div>

    <!-- Ledger -->
    <div class="section-title">Transaction Ledger</div>

    <% if (transactions.length === 0) { %>
      <div class="no-data">No transactions found for the selected period.</div>
    <% } else { %>
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Date</th>
          <th>Type</th>
          <th>Note</th>
          <th class="r">Debit (₹)</th>
          <th class="r">Credit (₹)</th>
          <th class="r">Balance (₹)</th>
        </tr>
      </thead>
      <tbody>
        <% transactions.forEach(function(t, i) {
          var isCredit  = t.type === 'sale_credit' || t.type === 'sale';
          var isPayment = t.type === 'payment_cash' || t.type === 'payment';
        %>
        <tr>
          <td style="color:#94a3b8;"><%= i+1 %></td>
          <td style="white-space:nowrap;"><%= new Date(t.date).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) %></td>
          <td><% if(isCredit){ %><span class="tag-c">Sale/Credit</span><% }else{ %><span class="tag-p">Rcvd Cash</span><% } %></td>
          <td style="color:#475569;max-width:180px;"><%= t.note || '—' %></td>
          <td class="r" style="color:#dc2626;"><%= isCredit  ? '₹'+t.amount.toLocaleString('en-IN') : '—' %></td>
          <td class="r" style="color:#16a34a;"><%= isPayment ? '₹'+t.amount.toLocaleString('en-IN') : '—' %></td>
          <td class="r" style="color:<%= t.running > 0 ? '#dc2626' : '#16a34a' %>;">₹<%= t.running.toLocaleString('en-IN') %></td>
        </tr>
        <% }) %>
      </tbody>
      <tfoot>
        <tr>
          <td colspan="4" style="color:#1e3a8a;">Total</td>
          <td class="r" style="color:#dc2626;">₹<%= totalCredit.toLocaleString('en-IN') %></td>
          <td class="r" style="color:#16a34a;">₹<%= totalReceived.toLocaleString('en-IN') %></td>
          <td class="r" style="color:<%= outstanding > 0 ? '#dc2626' : '#16a34a' %>;">₹<%= outstanding.toLocaleString('en-IN') %></td>
        </tr>
      </tfoot>
    </table>
    <% } %>

    <!-- Signature -->
    <div class="sig-block">
      <div class="sig-line">Customer Signature</div>
      <div class="sig-line">Authorised Signatory</div>
    </div>

    <!-- Footer -->
    <div class="report-footer">
      <span>MyPA · Customer Account Statement</span>
      <span>Printed on: <%= new Date().toLocaleString('en-IN') %></span>
    </div>

  </div>
</body>
</html>
