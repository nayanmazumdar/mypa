<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Customers – MyPA</title>
  <link rel="icon" type="image/png" href="/logo.png">
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <%- include('partials/navbar') %>
  <div class="container">
    <div class="flex-between page-header">
      <div>
        <h1>👥 Customers</h1>
        <p><%= business ? business.business_name : '' %> · <%= customers.length %> customer<%= customers.length !== 1 ? 's' : '' %></p>
      </div>
      <a href="/customers/new" class="btn btn-primary">+ Add Customer</a>
    </div>

    <!-- Search -->
    <form method="GET" action="/customers" style="margin-bottom:1.5rem;">
      <div style="display:flex;gap:.75rem;">
        <input type="text" class="form-control" name="q" value="<%= q %>" placeholder="🔍 Search by name or mobile..." style="flex:1;">
        <button type="submit" class="btn btn-secondary">Search</button>
        <% if (q) { %><a href="/customers" class="btn btn-secondary">Clear</a><% } %>
      </div>
    </form>




<%
  const totalReceivable = customers.reduce((sum, customer) => {
    return sum + (Number(customer.current_balance) || 0);
  }, 0);
%>

<div class="card" style="margin-bottom:1.5rem;">
  <div class="card-body">
    <div class="flex-between" style="align-items:center;">
      <div>
        <div class="text-muted text-sm">Total Customer Receivable</div>
        <div style="font-size:2rem;font-weight:700;color:var(--primary);">
          ₹<%= totalReceivable.toLocaleString('en-IN', {
              minimumFractionDigits: 2,
              maximumFractionDigits: 2
          }) %>
        </div>
      </div>

      <div style="text-align:right;">
        <div class="text-muted text-sm">Customers</div>
        <div style="font-size:1.5rem;font-weight:600;">
          <%= customers.length %>
        </div>
      </div>
    </div>
  </div>
</div>






    <% if (customers.length === 0) { %>
      <div class="card">
        <div class="card-body text-center" style="padding:3rem;">
          <div style="font-size:3rem;margin-bottom:1rem;">👥</div>
          <h3 style="margin-bottom:.5rem;"><%= q ? 'No customers found' : 'No customers yet' %></h3>
          <p class="text-muted" style="margin-bottom:1.5rem;"><%= q ? 'Try a different search.' : 'Add your first customer or share your QR code for self-registration.' %></p>
          <a href="/customers/new" class="btn btn-primary">+ Add Customer</a>
        </div>
      </div>
    <% } else { %>
      <!-- Cards view -->
      <div class="grid grid-3">
        <% customers.forEach(c => { %>
        <div class="card" style="transition:transform .2s;" onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform=''">
          <div class="card-body">
            <div class="flex gap-2" style="align-items:center;margin-bottom:1rem;">
              <% if (c.photo) { %>
                <img src="<%= c.photo %>" width="52" height="52" class="avatar">
              <% } else { %>
                <div class="avatar-placeholder" style="width:52px;height:52px;font-size:1.2rem;"><%= c.name.charAt(0).toUpperCase() %></div>
              <% } %>
              <div style="min-width:0;">
                <div class="fw-bold" style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><%= c.name %></div>
                <div class="text-muted text-sm">📞 <%= c.mobile %></div>
              </div>
            </div>
            <% if (c.address) { %>
              <p class="text-sm text-muted" style="margin-bottom:.5rem;">📍 <%= c.address %></p>
            <% } %>
            <div class="flex-between" style="margin-top:.75rem;padding-top:.75rem;border-top:1px solid var(--gray-100);">
              <div>
                <div class="text-sm text-muted">Current Due</div>
                <div style="font-size:1.1rem;font-weight:700;color:<%= c.current_balance > 0 ? 'var(--danger)' : 'var(--success)' %>;">₹<%= (c.current_balance||0).toLocaleString('en-IN') %></div>
              </div>
              <a href="/customers/<%= c.customer_id %>" class="btn btn-sm btn-outline">View →</a>
            </div>
          </div>
        </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</body>
</html>
