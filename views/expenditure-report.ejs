<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Expenditure Report – <%= user.name %></title>
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    body { font-family:'Segoe UI',Arial,sans-serif; font-size:13px; color:#111; background:#fff; }

    .screen-only {
      background:#f1f5f9; padding:.875rem 2rem; display:flex;
      align-items:center; gap:1rem; flex-wrap:wrap;
      border-bottom:2px solid #e2e8f0; position:sticky; top:0; z-index:10;
    }
    .screen-only h2 { font-size:1rem; color:#1e3a8a; flex:1; }
    .btn-print { background:#1e3a8a; color:#fff; border:none; padding:.5rem 1.4rem; border-radius:7px; font-size:.875rem; font-weight:700; cursor:pointer; }
    .btn-print:hover { background:#2d4fb5; }
    .btn-back { background:#fff; color:#1e3a8a; border:1.5px solid #1e3a8a; padding:.5rem 1.2rem; border-radius:7px; font-size:.875rem; font-weight:600; cursor:pointer; text-decoration:none; display:inline-block; }

    .report { max-width:860px; margin:1.5rem auto; padding:2rem; background:#fff; }

    /* Header */
    .report-header { display:flex; justify-content:space-between; align-items:flex-start; padding-bottom:1rem; border-bottom:3px solid #1e3a8a; margin-bottom:1.25rem; }
    .user-name { font-size:1.35rem; font-weight:800; color:#1e3a8a; }
    .user-meta { font-size:.8rem; color:#475569; margin-top:.3rem; line-height:1.7; }
    .report-title { text-align:right; }
    .report-title h1 { font-size:1.05rem; font-weight:800; color:#1e3a8a; text-transform:uppercase; letter-spacing:.05em; }
    .report-title p  { font-size:.78rem; color:#64748b; margin-top:.25rem; }

    /* Date banner */
    .date-banner { background:#1e3a8a; color:#fff; border-radius:7px; padding:.6rem 1.1rem; margin-bottom:1.25rem; display:flex; justify-content:space-between; align-items:center; font-size:.82rem; }
    .date-banner strong { font-size:.95rem; }

    /* Summary tiles */
    .summary-row { display:grid; grid-template-columns:repeat(4,1fr); gap:.75rem; margin-bottom:1.25rem; }
    .tile { border:1px solid #e2e8f0; border-radius:8px; padding:.75rem 1rem; text-align:center; }
    .tile .t-lbl { font-size:.68rem; font-weight:700; text-transform:uppercase; color:#94a3b8; letter-spacing:.04em; }
    .tile .t-val { font-size:1.1rem; font-weight:800; margin-top:.25rem; color:#1e3a8a; }

    /* Category summary */
    .cat-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:.6rem; margin-bottom:1.25rem; }
    .cat-tile { background:#f8fafc; border:1px solid #e2e8f0; border-radius:7px; padding:.6rem .875rem; display:flex; align-items:center; gap:.6rem; }
    .cat-icon { font-size:1.25rem; }
    .cat-name { font-size:.72rem; font-weight:700; color:#475569; text-transform:uppercase; letter-spacing:.03em; }
    .cat-total { font-size:.95rem; font-weight:800; color:#1e3a8a; }
    .cat-count { font-size:.7rem; color:#94a3b8; }

    /* Table */
    .section-title { font-size:.82rem; font-weight:700; color:#1e3a8a; text-transform:uppercase; letter-spacing:.05em; margin-bottom:.5rem; padding-bottom:.4rem; border-bottom:2px solid #e2e8f0; }
    table { width:100%; border-collapse:collapse; font-size:.82rem; }
    thead tr { background:#1e3a8a; color:#fff; }
    thead th { padding:.55rem .75rem; text-align:left; font-weight:700; }
    thead th.r { text-align:right; }
    tbody tr:nth-child(even) { background:#f8fafc; }
    tbody td { padding:.5rem .75rem; border-bottom:1px solid #f1f5f9; vertical-align:middle; }
    tbody td.r { text-align:right; font-weight:700; }
    tfoot tr { background:#dbeafe; }
    tfoot td { padding:.65rem .75rem; font-weight:800; font-size:.85rem; }
    tfoot td.r { text-align:right; font-size:.95rem; color:#1e3a8a; }

    .badge { display:inline-block; padding:.15rem .55rem; background:#fef9c3; color:#854d0e; border-radius:12px; font-size:.7rem; font-weight:700; }
    .pay-badge { display:inline-block; padding:.15rem .55rem; background:#f1f5f9; color:#475569; border-radius:12px; font-size:.7rem; font-weight:600; }
    .no-data { text-align:center; padding:3rem; color:#94a3b8; }

    .sig-block { display:grid; grid-template-columns:1fr 1fr; gap:3rem; margin-top:3rem; }
    .sig-line  { border-top:1px solid #94a3b8; padding-top:.4rem; font-size:.72rem; color:#64748b; text-align:center; }
    .report-footer { margin-top:1.5rem; padding-top:.75rem; border-top:1px solid #e2e8f0; display:flex; justify-content:space-between; font-size:.7rem; color:#94a3b8; }

    @media print {
      .screen-only { display:none !important; }
      body { font-size:12px; }
      .report { margin:0; padding:1cm; max-width:100%; }
      @page { size:A4; margin:1.5cm; }
    }
  </style>
</head>
<body>

  <!-- Screen controls -->
  <div class="screen-only">
    <h2>📄 Expenditure Report — <%= user.name %></h2>
    <a href="/expenditures" class="btn-back">← Back</a>
    <button class="btn-print" onclick="window.print()">🖨️ Print / Save as PDF</button>
  </div>

  <div class="report">

    <!-- Header -->
    <div class="report-header">
      <div>
        <% if (user.profile_photo) { %>
          <img src="<%= user.profile_photo %>" height="40" style="border-radius:50%;margin-bottom:.4rem;display:block;">
        <% } %>
        <div class="user-name"><%= user.name %></div>
        <div class="user-meta">
          <% if (user.email)      { %><%= user.email %><br><% } %>
          <% if (user.mobile)     { %>📞 <%= user.mobile %><br><% } %>
          <% if (user.city || user.state) { %>📍 <%= [user.city, user.state].filter(Boolean).join(', ') %><% } %>
        </div>
      </div>
      <div class="report-title">
        <h1>Expenditure Statement</h1>
        <p>Generated: <%= new Date().toLocaleDateString('en-IN',{day:'numeric',month:'long',year:'numeric'}) %></p>
        <% if (category) { %><p style="margin-top:.25rem;font-size:.78rem;">Category: <strong><%= category %></strong></p><% } %>
      </div>
    </div>

    <!-- Date banner -->
    <div class="date-banner">
      <span>📅 Period</span>
      <strong>
        <%= from ? new Date(from).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) : 'All time' %>
        &nbsp;→&nbsp;
        <%= to   ? new Date(to).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'})   : 'Today' %>
      </strong>
      <span><%= expenditures.length %> entr<%= expenditures.length !== 1 ? 'ies' : 'y' %></span>
    </div>

    <!-- Summary tiles -->
    <%
      var payModes = {};
      expenditures.forEach(function(e) {
        payModes[e.payment_mode] = (payModes[e.payment_mode] || 0) + e.amount;
      });
      var topMode = Object.keys(payModes).sort((a,b) => payModes[b]-payModes[a])[0] || '—';
      var topCat  = summary.length > 0 ? summary[0].category : '—';
    %>
    <div class="summary-row">
      <div class="tile">
        <div class="t-lbl">Total Spent</div>
        <div class="t-val" style="color:#dc2626;">₹<%= total.toLocaleString('en-IN') %></div>
      </div>
      <div class="tile">
        <div class="t-lbl">Entries</div>
        <div class="t-val"><%= expenditures.length %></div>
      </div>
      <div class="tile">
        <div class="t-lbl">Top Category</div>
        <div class="t-val" style="font-size:.9rem;"><%= topCat %></div>
      </div>
      <div class="tile">
        <div class="t-lbl">Top Payment Mode</div>
        <div class="t-val" style="font-size:.9rem;text-transform:capitalize;"><%= topMode %></div>
      </div>
    </div>

    <!-- Category breakdown -->
    <% if (summary.length > 0) { %>
    <div class="section-title" style="margin-bottom:.75rem;">Category Breakdown</div>
    <%
      var catIcons = {
        'Food & Dining':'🍽️','Groceries':'🛒','Transport':'🚗','Utilities':'💡',
        'Rent':'🏠','Healthcare':'💊','Education':'📚','Shopping':'🛍️',
        'Entertainment':'🎬','Fuel':'⛽','Mobile/Internet':'📱','EMI/Loan':'🏦',
        'Insurance':'🛡️','Investment':'📈','Personal Care':'💆','Travel':'✈️',
        'Gifts':'🎁','Other':'📦'
      };
    %>
    <div class="cat-grid" style="margin-bottom:1.25rem;">
      <% summary.forEach(function(s) { %>
      <div class="cat-tile">
        <div class="cat-icon"><%= catIcons[s.category] || '📦' %></div>
        <div>
          <div class="cat-name"><%= s.category %></div>
          <div class="cat-total">₹<%= s.total.toLocaleString('en-IN') %></div>
          <div class="cat-count"><%= s.count %> entr<%= s.count===1?'y':'ies' %></div>
        </div>
      </div>
      <% }) %>
    </div>
    <% } %>

    <!-- Expenditure table -->
    <div class="section-title">All Entries</div>

    <% if (expenditures.length === 0) { %>
      <div class="no-data">No expenditures found for the selected period.</div>
    <% } else { %>
    <%
      var payIcons = { cash:'💵', upi:'📱', card:'💳', netbanking:'🏦', cheque:'📄' };
    %>
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Date</th>
          <th>Category</th>
          <th>Description</th>
          <th>Payment</th>
          <th class="r">Amount (₹)</th>
        </tr>
      </thead>
      <tbody>
        <% expenditures.forEach(function(e, i) { %>
        <tr>
          <td style="color:#94a3b8;"><%= i+1 %></td>
          <td style="white-space:nowrap;"><%= new Date(e.date).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) %></td>
          <td><span class="badge"><%= catIcons[e.category] || '📦' %> <%= e.category %></span></td>
          <td style="color:#475569;max-width:200px;"><%= e.description || '—' %></td>
          <td><span class="pay-badge"><%= payIcons[e.payment_mode] || '💵' %> <%= e.payment_mode || 'cash' %></span></td>
          <td class="r" style="color:#dc2626;">₹<%= e.amount.toLocaleString('en-IN') %></td>
        </tr>
        <% }) %>
      </tbody>
      <tfoot>
        <tr>
          <td colspan="5">Total</td>
          <td class="r">₹<%= total.toLocaleString('en-IN') %></td>
        </tr>
      </tfoot>
    </table>
    <% } %>

    <!-- Signature -->
    <div class="sig-block">
      <div class="sig-line">Verified by</div>
      <div class="sig-line">Date</div>
    </div>

    <!-- Footer -->
    <div class="report-footer">
      <span>MyPA · Personal Expenditure Statement</span>
      <span>Printed on: <%= new Date().toLocaleString('en-IN') %></span>
    </div>

  </div>
</body>
</html>
