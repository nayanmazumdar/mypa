<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>MyPA – Simply Assist</title>
  <link rel="icon" type="image/png" href="/logo.png">
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <%- include('partials/navbar', { user: null }) %>

  <!-- Hero -->
  <section class="hero">
    <img src="/logo.png" alt="MyPA Logo" style="width:110px;height:110px;border-radius:50%;border:4px solid rgba(255,255,255,.4);margin-bottom:1.25rem;object-fit:cover;">
    <h1><span style="color:#fff;">My</span><span style="color:var(--gold-bright);">PA</span> – Simply Assist</h1>
    <p>Your complete Personal Assistant — manage profiles, track credit, handle customers, and grow your business all in one place.</p>
    <div class="hero-btns">
      <a href="/register" class="btn btn-white">🚀 Get Started Free</a>
      <a href="/login" class="btn btn-ghost">Sign In</a>
    </div>
  </section>

  <!-- Features -->
  <section style="padding:4rem 1.5rem; background:#fff;">
    <div style="max-width:1200px;margin:0 auto;">
      <h2 style="text-align:center;font-size:2rem;font-weight:800;margin-bottom:.5rem;">Everything You Need</h2>
      <p style="text-align:center;color:#6b7280;margin-bottom:3rem;">One platform for individuals and businesses</p>
      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon">👤</div>
          <h3>Personal Profiles</h3>
          <p>Manage your identity with photo, documents, and profile completeness tracking.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🏪</div>
          <h3>Business Ledger</h3>
          <p>Shopkeepers can manage customers, track credit sales, and handle dues efficiently.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">📱</div>
          <h3>QR Self-Registration</h3>
          <p>Customers scan your shop QR to self-register for credit — no manual entry needed.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🪪</div>
          <h3>Digital Customer Cards</h3>
          <p>Auto-generated customer cards with photo, QR, and outstanding due info.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">📄</div>
          <h3>Document Vault</h3>
          <p>Securely store Aadhaar, PAN, Trade License, and GST documents privately.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">📊</div>
          <h3>Profile Completeness</h3>
          <p>Visual score shows what's missing and encourages you to complete your profile.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- USP strip -->
  <section style="background:var(--primary);color:#fff;padding:3rem 1.5rem;">
    <div style="max-width:1200px;margin:0 auto;text-align:center;">
      <h2 style="font-size:1.6rem;font-weight:800;margin-bottom:2rem;">Suitable For Every Small Business</h2>
      <div style="display:flex;flex-wrap:wrap;gap:.75rem;justify-content:center;">
        <% ['🛒 Grocery Store','💊 Pharmacy','📚 Stationery','🔧 Hardware','🍰 Bakery','☕ Tea Stall','🍽️ Restaurant','📱 Mobile Shop','👗 Clothing','⚡ Electronics'].forEach(cat => { %>
          <span style="background:rgba(255,255,255,.15);border-radius:8px;padding:.5rem 1rem;font-size:.9rem;"><%=cat%></span>
        <% }) %>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section style="padding:4rem 1.5rem;text-align:center;">
    <h2 style="font-size:1.8rem;font-weight:800;margin-bottom:1rem;">Ready to get started?</h2>
    <p style="color:#6b7280;margin-bottom:2rem;">Join thousands of individuals and shop owners who trust MyPA.</p>
    <a href="/register" class="btn btn-primary" style="font-size:1rem;padding:.85rem 2rem;">Create Free Account</a>
  </section>

  <footer style="background:var(--gray-800);color:var(--gray-400);text-align:center;padding:1.5rem;">
    <img src="/logo.png" alt="MyPA" style="width:36px;height:36px;border-radius:50%;vertical-align:middle;margin-right:.5rem;opacity:.7;">
    <span>© 2026 MyPA – Simply Assist · Profile & Identity Management Platform</span>
  </footer>
</body>
</html>
