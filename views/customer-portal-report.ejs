<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Account Statement – <%= customer.name %></title>
  <style>
    *{margin:0;padding:0;box-sizing:border-box;}
    body{font-family:'Segoe UI',Arial,sans-serif;font-size:13px;color:#111;background:#fff;}
    .screen-only{background:#f1f5f9;padding:.875rem 2rem;display:flex;align-items:center;gap:1rem;flex-wrap:wrap;border-bottom:2px solid #e2e8f0;position:sticky;top:0;z-index:10;}
    .screen-only h2{font-size:1rem;color:#1e3a8a;flex:1;}
    .btn-print{background:#1e3a8a;color:#fff;border:none;padding:.5rem 1.4rem;border-radius:7px;font-size:.875rem;font-weight:700;cursor:pointer;}
    .btn-back{background:#fff;color:#1e3a8a;border:1.5px solid #1e3a8a;padding:.5rem 1.2rem;border-radius:7px;font-size:.875rem;font-weight:600;text-decoration:none;display:inline-block;}
    .report{max-width:860px;margin:1.5rem auto;padding:2rem;}
    .rh{display:flex;justify-content:space-between;align-items:flex-start;padding-bottom:1rem;border-bottom:3px solid #1e3a8a;margin-bottom:1.25rem;}
    .biz-name{font-size:1.3rem;font-weight:800;color:#1e3a8a;}
    .biz-meta{font-size:.8rem;color:#475569;margin-top:.25rem;line-height:1.7;}
    .rt{text-align:right;}
    .rt h1{font-size:1rem;font-weight:800;color:#1e3a8a;text-transform:uppercase;letter-spacing:.05em;}
    .rt p{font-size:.78rem;color:#64748b;margin-top:.2rem;}
    .cbox{background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;padding:.875rem 1.25rem;margin-bottom:1.25rem;display:grid;grid-template-columns:1fr 1fr;gap:.5rem .75rem;}
    .lbl{font-size:.7rem;font-weight:700;text-transform:uppercase;color:#94a3b8;letter-spacing:.04em;}
    .val{font-size:.875rem;font-weight:600;color:#1e293b;margin-top:.1rem;}
    .date-banner{background:#1e3a8a;color:#fff;border-radius:7px;padding:.6rem 1.1rem;margin-bottom:1.25rem;display:flex;justify-content:space-between;align-items:center;font-size:.82rem;}
    .sum-row{display:grid;grid-template-columns:1fr 1fr 1fr;gap:.75rem;margin-bottom:1.25rem;}
    .tile{border:1px solid #e2e8f0;border-radius:8px;padding:.75rem 1rem;text-align:center;}
    .tile .tl{font-size:.68rem;font-weight:700;text-transform:uppercase;color:#94a3b8;letter-spacing:.04em;}
    .tile .tv{font-size:1.1rem;font-weight:800;margin-top:.25rem;}
    .sec{font-size:.82rem;font-weight:700;color:#1e3a8a;text-transform:uppercase;letter-spacing:.05em;margin-bottom:.5rem;padding-bottom:.4rem;border-bottom:2px solid #e2e8f0;}
    table{width:100%;border-collapse:collapse;font-size:.82rem;}
    thead tr{background:#1e3a8a;color:#fff;}
    thead th{padding:.55rem .75rem;text-align:left;font-weight:700;}
    thead th.r{text-align:right;}
    tbody tr:nth-child(even){background:#f8fafc;}
    tbody td{padding:.5rem .75rem;border-bottom:1px solid #f1f5f9;vertical-align:middle;}
    tfoot tr{background:#dbeafe;}
    tfoot td{padding:.65rem .75rem;font-weight:800;}
    tfoot td.r{text-align:right;font-size:.95rem;color:#1e3a8a;}
    .tc{display:inline-block;padding:.15rem .5rem;background:#fff3f3;color:#dc2626;border-radius:12px;font-size:.7rem;font-weight:700;}
    .tp{display:inline-block;padding:.15rem .5rem;background:#f0fdf4;color:#16a34a;border-radius:12px;font-size:.7rem;font-weight:700;}
    .sig-block{display:grid;grid-template-columns:1fr 1fr;gap:3rem;margin-top:3rem;}
    .sig-line{border-top:1px solid #94a3b8;padding-top:.4rem;font-size:.72rem;color:#64748b;text-align:center;}
    .foot{margin-top:1.5rem;padding-top:.75rem;border-top:1px solid #e2e8f0;display:flex;justify-content:space-between;font-size:.7rem;color:#94a3b8;}
    @media print{.screen-only{display:none!important;}body{font-size:12px;}.report{margin:0;padding:1cm;max-width:100%;}@page{size:A4;margin:1.5cm;}}
  </style>
</head>
<body>
  <div class="screen-only">
    <h2>📄 Account Statement – <%= customer.name %></h2>
    <a href="/customer-portal" class="btn-back">← Back</a>
    <button class="btn-print" onclick="window.print()">🖨️ Print / Save as PDF</button>
  </div>

  <div class="report">
    <!-- Header -->
    <div class="rh">
      <div>
        <% if(business && business.business_logo){ %>
          <img src="<%= business.business_logo %>" height="40" style="margin-bottom:.4rem;display:block;">
        <% } %>
        <div class="biz-name"><%= business ? business.business_name : 'MyPA' %></div>
        <div class="biz-meta">
          <% if(business && business.address){ %><%= business.address %><br><% } %>
          <% if(business && business.gst_number){ %>GST: <%= business.gst_number %><br><% } %>
        </div>
      </div>
      <div class="rt">
        <h1>Account Statement</h1>
        <p>Generated: <%= new Date().toLocaleDateString('en-IN',{day:'numeric',month:'long',year:'numeric'}) %></p>
      </div>
    </div>

    <!-- Customer info -->
    <div class="cbox">
      <div><div class="lbl">Customer Name</div><div class="val"><%= customer.name %></div></div>
      <div><div class="lbl">Mobile</div><div class="val"><%= customer.mobile %></div></div>
      <% if(customer.address){ %><div><div class="lbl">Address</div><div class="val"><%= customer.address %></div></div><% } %>
      <div><div class="lbl">Credit Limit</div><div class="val">₹<%= (customer.credit_limit||0).toLocaleString('en-IN') %></div></div>
    </div>

    <!-- Date range -->
    <div class="date-banner">
      <span>📅 Period</span>
      <strong>
        <%= from?new Date(from).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}):'All time' %>
        &nbsp;→&nbsp;
        <%= to?new Date(to).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}):'Today' %>
      </strong>
      <span><%= transactions.length %> transaction<%= transactions.length!==1?'s':'' %></span>
    </div>

    <!-- Summary -->
    <div class="sum-row">
      <div class="tile"><div class="tl">Total Credit Given</div><div class="tv" style="color:#dc2626;">₹<%= totalCredit.toLocaleString('en-IN') %></div></div>
      <div class="tile"><div class="tl">Total Cash Received</div><div class="tv" style="color:#16a34a;">₹<%= totalReceived.toLocaleString('en-IN') %></div></div>
      <div class="tile"><div class="tl">Outstanding Balance</div><div class="tv" style="color:<%= outstanding>0?'#dc2626':'#16a34a' %>;">₹<%= outstanding.toLocaleString('en-IN') %></div></div>
    </div>

    <!-- Ledger -->
    <div class="sec">Transaction Ledger</div>
    <% if(transactions.length===0){ %>
      <p style="text-align:center;padding:2rem;color:#94a3b8;">No transactions for the selected period.</p>
    <% }else{ %>
    <table>
      <thead>
        <tr><th>#</th><th>Date</th><th>Type</th><th>Note</th><th class="r">Debit (₹)</th><th class="r">Credit (₹)</th><th class="r">Balance (₹)</th></tr>
      </thead>
      <tbody>
        <% transactions.forEach(function(t,i){
          var isC=t.type==='sale_credit'||t.type==='sale';
          var isP=t.type==='payment_cash'||t.type==='payment';
        %>
        <tr>
          <td style="color:#94a3b8;"><%= i+1 %></td>
          <td style="white-space:nowrap;"><%= new Date(t.date).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) %></td>
          <td><%if(isC){%><span class="tc">Sale/Credit</span><%}else{%><span class="tp">Rcvd Cash</span><%}%></td>
          <td style="color:#475569;"><%= t.note||'—' %></td>
          <td style="text-align:right;color:#dc2626;"><%=isC?'₹'+t.amount.toLocaleString('en-IN'):'—'%></td>
          <td style="text-align:right;color:#16a34a;"><%=isP?'₹'+t.amount.toLocaleString('en-IN'):'—'%></td>
          <td style="text-align:right;font-weight:700;color:<%= t.running>0?'#dc2626':'#16a34a' %>;">₹<%= t.running.toLocaleString('en-IN') %></td>
        </tr>
        <%})%>
      </tbody>
      <tfoot>
        <tr>
          <td colspan="4">Total</td>
          <td style="text-align:right;color:#dc2626;">₹<%= totalCredit.toLocaleString('en-IN') %></td>
          <td style="text-align:right;color:#16a34a;">₹<%= totalReceived.toLocaleString('en-IN') %></td>
          <td class="r" style="color:<%= outstanding>0?'#dc2626':'#16a34a' %>;">₹<%= outstanding.toLocaleString('en-IN') %></td>
        </tr>
      </tfoot>
    </table>
    <%}%>

    <div class="sig-block">
      <div class="sig-line">Customer Signature</div>
      <div class="sig-line">Authorised Signatory</div>
    </div>
    <div class="foot">
      <span><%= business?business.business_name:'MyPA' %> · Customer Account Statement</span>
      <span>Printed: <%= new Date().toLocaleString('en-IN') %></span>
    </div>
  </div>
</body>
</html>
