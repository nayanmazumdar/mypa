<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Digital Card – <%= customer.name %></title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <%- include('partials/navbar') %>
  <div class="container" style="max-width:500px;">
    <div class="page-header flex-between">
      <h1>🪪 Digital Customer Card</h1>
      <a href="/customers/<%= customer.customer_id %>" class="btn btn-secondary">← Back</a>
    </div>

    <!-- Printable card -->
    <div id="printCard">
      <div class="customer-card" style="max-width:100%;margin-bottom:1.5rem;">
        <div class="brand" style="display:flex;justify-content:space-between;align-items:center;">
          <span>MyPA · Digital Customer Card</span>
        </div>
        <div style="display:flex;gap:1rem;align-items:center;margin-bottom:1rem;">
          <% if (customer.photo) { %>
            <img src="<%= customer.photo %>" width="70" height="70" style="border-radius:50%;border:2px solid rgba(255,255,255,.4);object-fit:cover;">
          <% } else { %>
            <div style="width:70px;height:70px;border-radius:50%;background:rgba(255,255,255,.2);display:flex;align-items:center;justify-content:center;font-size:1.8rem;">
              <%= customer.name.charAt(0).toUpperCase() %>
            </div>
          <% } %>
          <div>
            <div class="customer-name"><%= customer.name %></div>
            <div class="customer-info">
              📞 <%= customer.mobile %><br>
              <% if (customer.address) { %>📍 <%= customer.address %><br><% } %>
            </div>
          </div>
        </div>
        <div class="due">
          <div>
            <%
              var limit = customer.credit_limit || 0;
              var tier, tierColor;
              if (limit >= 20000 && limit <= 50000)      { tier = 'Premium';  tierColor = '#7c3aed'; }
              else if (limit > 10000 && limit < 20000)   { tier = 'Business'; tierColor = '#0369a1'; }
              else if (limit > 5000  && limit <= 10000)  { tier = 'Standard'; tierColor = '#0f766e'; }
              else                                        { tier = 'Economy';  tierColor = '#6b7280'; }
            %>
            <div class="due-label">Membership Tier</div>
            <div class="due-amount" style="font-size:1.1rem;letter-spacing:.05em;"><%= tier %></div>
          </div>
          <div style="display:flex;flex-direction:column;align-items:center;gap:.3rem;">
            <img src="<%= qrDataUrl %>" width="70" height="70" style="border-radius:6px;">
            <% if (business) { %>
              <span style="font-size:.68rem;font-weight:700;color:#facc15;letter-spacing:.05em;text-align:center;line-height:1.3;display:flex;align-items:center;gap:.3rem;">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#facc15" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
                &nbsp;<%= business.business_name %>
              </span>
            <% } %>
          </div>
        </div>
      </div>
    </div>

    <!-- QR code large -->
    <div class="card">
      <div class="card-header"><h2>📱 Customer QR Code</h2></div>
      <div class="card-body qr-wrap">
        <img src="<%= qrDataUrl %>" width="220" height="220" alt="Customer QR">
        <p class="text-muted text-sm text-center">Shopkeeper scans this to instantly open customer record</p>
        <button onclick="window.print()" class="btn btn-primary">🖨️ Print Card</button>
      </div>
    </div>
  </div>

  <style>
    @media print {
      * { -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; }
      html, body { margin:0; padding:0; background:#fff; }
      .navbar, .page-header, .card, .btn { display:none !important; }
      .container { padding:0 !important; margin:0 !important; max-width:100% !important; }
      #printCard { display:block !important; }
      #printCard .customer-card {
        width: 85.6mm !important;
        height: 54mm !important;
        margin: 0 !important;
        padding: 4mm 5mm !important;
        border-radius: 4mm !important;
        box-shadow: none !important;
        overflow: hidden !important;
        position: relative !important;
      }
      #printCard .brand         { font-size: 6pt !important; margin-bottom: 1.5mm !important; }
      #printCard .customer-name { font-size: 9pt !important; }
      #printCard .customer-info { font-size: 6.5pt !important; }
      #printCard .due           { margin-top: 2mm !important; }
      #printCard .due-label     { font-size: 5.5pt !important; }
      #printCard .due-amount    { font-size: 8.5pt !important; }
      #printCard img            { width: 12mm !important; height: 12mm !important; }
      @page { size: 85.6mm 54mm; margin: 0; }
    }
  </style>
</body>
</html>
