<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= customer ? 'Edit' : 'Add' %> Customer – MyPA</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <%- include('partials/navbar') %>
  <div class="container" style="max-width:700px;">
    <div class="page-header flex-between">
      <div>
        <h1><%= customer ? '✏️ Edit Customer' : '➕ Add Customer' %></h1>
        <p><%= customer ? 'Update customer information' : 'Create a new customer record' %></p>
      </div>
      <a href="/customers" class="btn btn-secondary">← Back</a>
    </div>

    <% if (error) { %><div class="alert alert-danger">⚠️ <%= error %></div><% } %>

    <div class="card">
      <div class="card-body">
        <form action="/customers/<%= customer ? customer.customer_id + '/edit' : 'new' %>" method="POST" enctype="multipart/form-data">

          <div class="form-section-title">Mandatory Fields</div>
          <div class="grid grid-2">
            <div class="form-group">
              <label class="form-label">Customer Name <span class="required">*</span></label>
              <input type="text" class="form-control" name="name" value="<%= customer ? customer.name : '' %>" required placeholder="Full name">
            </div>
            <div class="form-group">
              <label class="form-label">Mobile Number <span class="required">*</span></label>
              <input type="tel" class="form-control" name="mobile" value="<%= customer ? customer.mobile : '' %>" required placeholder="10-digit mobile">
            </div>
          </div>

          <div class="form-section-title" style="margin-top:1.5rem;">Optional Fields</div>
          <div class="grid grid-2">
            <div class="form-group">
              <label class="form-label">Alternate Mobile</label>
              <input type="tel" class="form-control" name="alternate_mobile" value="<%= customer ? customer.alternate_mobile : '' %>">
            </div>
            <div class="form-group">
              <label class="form-label">Occupation</label>
              <input type="text" class="form-control" name="occupation" value="<%= customer ? customer.occupation : '' %>">
            </div>
          </div>
          <div class="form-group">
            <label class="form-label">Address</label>
            <input type="text" class="form-control" name="address" value="<%= customer ? customer.address : '' %>" placeholder="Full address">
          </div>
          <div class="form-group">
            <label class="form-label">Reference Person</label>
            <input type="text" class="form-control" name="reference_person" value="<%= customer ? customer.reference_person : '' %>" placeholder="Who referred this customer?">
          </div>
          <div class="form-group">
            <label class="form-label">Credit Limit (₹)</label>
            <input type="number" class="form-control" name="credit_limit" value="<%= customer ? customer.credit_limit : 1000 %>" min="0">
          </div>
          <div class="form-group">
            <label class="form-label">Customer Photo</label>
            <% if (customer && customer.photo) { %>
              <img src="<%= customer.photo %>" width="60" height="60" class="avatar" style="margin-bottom:.5rem;display:block;">
            <% } %>
            <input type="file" class="form-control" name="photo" accept="image/jpeg,image/png,image/webp">
            <p class="form-hint">JPG, PNG, WEBP · Max 5 MB</p>
          </div>

          <div style="display:flex;gap:.75rem;justify-content:flex-end;margin-top:.5rem;">
            <a href="/customers" class="btn btn-secondary">Cancel</a>
            <button type="submit" class="btn btn-primary">💾 <%= customer ? 'Update' : 'Add Customer' %></button>
          </div>
        </form>
      </div>
    </div>
  </div>
</body>
</html>
