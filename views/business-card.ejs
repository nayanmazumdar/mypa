<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Business Card – <%= business.business_name %></title>
  <link rel="icon" type="image/png" href="/logo.png">
  <link rel="stylesheet" href="/style.css">
  <style>
    .biz-card {
      background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
      color: #fff;
      border-radius: 14px;
      padding: 1.25rem 1.5rem;
      max-width: 340px;
      margin: 0 auto;
      box-shadow: 0 8px 32px rgba(0,0,0,.18);
      position: relative;
      overflow: hidden;
    }
    .biz-card::before {
      content:'';
      position:absolute;
      top:-40px;right:-40px;
      width:160px;height:160px;
      background:rgba(255,255,255,.07);
      border-radius:50%;
    }
    .biz-card::after {
      content:'';
      position:absolute;
      bottom:-30px;left:-30px;
      width:120px;height:120px;
      background:rgba(255,255,255,.05);
      border-radius:50%;
    }
    .bc-brand  { font-size:.65rem; opacity:.7; letter-spacing:.08em; text-transform:uppercase; margin-bottom:.75rem; display:flex; align-items:center; gap:.35rem; }
    .bc-logo   { width:38px; height:38px; border-radius:6px; object-fit:cover; border:2px solid rgba(255,255,255,.3); }
    .bc-logo-placeholder { width:38px; height:38px; border-radius:6px; background:rgba(255,255,255,.2); display:flex; align-items:center; justify-content:center; font-size:1.1rem; border:2px solid rgba(255,255,255,.3); }
    .bc-name   { font-size:1.15rem; font-weight:800; letter-spacing:.02em; margin-bottom:.2rem; }
    .bc-type   { font-size:.72rem; opacity:.75; margin-bottom:.75rem; }
    .bc-info   { font-size:.72rem; opacity:.85; line-height:1.8; margin-bottom:.75rem; }
    .bc-bottom { display:flex; justify-content:space-between; align-items:flex-end; margin-top:.5rem; padding-top:.75rem; border-top:1px solid rgba(255,255,255,.2); }
    .bc-owner  { font-size:.7rem; opacity:.8; }
    .bc-owner strong { display:block; font-size:.82rem; opacity:1; font-weight:700; }
    .bc-qr img { border-radius:6px; border:2px solid rgba(255,255,255,.3); }
    .bc-qr-label { font-size:.55rem; opacity:.65; text-align:center; margin-top:.2rem; letter-spacing:.04em; }

    @media print {
      * { -webkit-print-color-adjust:exact !important; print-color-adjust:exact !important; }
      html, body { margin:0; padding:0; background:#fff; }
      .navbar, .page-header, .card, .btn { display:none !important; }
      .container { padding:0 !important; margin:0 !important; max-width:100% !important; }
      #printCard { display:block !important; }
      #printCard .biz-card {
        width: 85.6mm !important;
        height: 54mm !important;
        max-width: none !important;
        margin: 0 !important;
        padding: 4mm 5mm !important;
        border-radius: 4mm !important;
        box-shadow: none !important;
        overflow: hidden !important;
      }
      #printCard .bc-brand  { font-size:5pt !important; margin-bottom:1.5mm !important; }
      #printCard .bc-name   { font-size:9pt !important; }
      #printCard .bc-type   { font-size:6pt !important; margin-bottom:1.5mm !important; }
      #printCard .bc-info   { font-size:6pt !important; margin-bottom:1.5mm !important; }
      #printCard .bc-logo, #printCard .bc-logo-placeholder { width:9mm !important; height:9mm !important; }
      #printCard .bc-qr img { width:12mm !important; height:12mm !important; }
      #printCard .bc-owner strong { font-size:6.5pt !important; }
      #printCard .bc-owner        { font-size:5.5pt !important; }
      @page { size:85.6mm 54mm; margin:0; }
    }
  </style>
</head>
<body>
  <%- include('partials/navbar') %>
  <div class="container" style="max-width:500px;">
    <div class="page-header flex-between">
      <h1>🪪 Business Card</h1>
      <a href="/profile" class="btn btn-secondary">← Back</a>
    </div>

    <div id="printCard">
      <div class="biz-card">
        <!-- Brand bar -->
        <div class="bc-brand">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,.7)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
          MyPA · Business Card
        </div>

        <!-- Logo + Name -->
        <div style="display:flex;align-items:center;gap:.75rem;margin-bottom:.5rem;">
          <% if (business.business_logo) { %>
            <img src="<%= business.business_logo %>" class="bc-logo">
          <% } else { %>
            <div class="bc-logo-placeholder">🏪</div>
          <% } %>
          <div>
            <div class="bc-name"><%= business.business_name %></div>
            <div class="bc-type"><%= business.business_type || '' %></div>
          </div>
        </div>

        <!-- Info -->
        <div class="bc-info">
          <% if (business.address)    { %>📍 <%= business.address %><br><% } %>
          <% if (business.gst_number) { %>GST: <%= business.gst_number %><br><% } %>
          <% if (user.mobile)         { %>📞 <%= user.mobile %><% } %>
        </div>

        <!-- Bottom row -->
        <div class="bc-bottom">
          <div class="bc-owner">
            Proprietor
            <strong><%= business.owner_name || user.name %></strong>
          </div>
          <div class="bc-qr">
            <img src="<%= qrDataUrl %>" width="55" height="55">
            <div class="bc-qr-label">SCAN TO REGISTER</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Print button -->
    <div class="card" style="margin-top:1.5rem;">
      <div class="card-body" style="text-align:center;">
        <p class="text-muted text-sm" style="margin-bottom:1rem;">Card prints at driving license size (85.6 × 54 mm)</p>
        <button onclick="window.print()" class="btn btn-primary">🖨️ Print Business Card</button>
      </div>
    </div>

  </div>
</body>
</html>
