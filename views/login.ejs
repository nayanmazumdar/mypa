<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login – MyPA</title>
  <link rel="icon" type="image/png" href="/logo.png">
  <link rel="stylesheet" href="/style.css">
  <style>
    .role-grid { display:grid; grid-template-columns:1fr 1fr; gap:.75rem; margin-bottom:1.5rem; }
    .role-btn {
      display:flex; flex-direction:column; align-items:center; justify-content:center;
      gap:.4rem; padding:1rem .75rem; border:2px solid var(--gray-200);
      border-radius:12px; background:#fff; cursor:pointer; text-decoration:none;
      transition:all .2s; color:var(--gray-700);
    }
    .role-btn:hover { transform:translateY(-2px); box-shadow:0 4px 16px rgba(0,0,0,.08); }
    .role-btn.active { border-color:var(--primary); background:#f0f4ff; color:var(--primary); }
    .role-btn .icon { font-size:1.75rem; line-height:1; }
    .role-btn .label { font-size:.82rem; font-weight:700; letter-spacing:.01em; }
    .role-btn .sub { font-size:.72rem; color:var(--gray-400); font-weight:400; }
    .role-btn.admin-btn:hover  { border-color:#dc2626; background:#fff1f2; color:#dc2626; }
    .role-btn.shop-btn:hover   { border-color:#ca8a04; background:#fefce8; color:#ca8a04; }
    .role-btn.indiv-btn:hover  { border-color:#2563eb; background:#eff6ff; color:#2563eb; }
    .role-btn.cust-btn:hover   { border-color:#16a34a; background:#f0fdf4; color:#16a34a; }
    .login-form { display:none; }
    .login-form.show { display:block; }
    .back-link { display:inline-flex;align-items:center;gap:.3rem;font-size:.82rem;color:var(--gray-400);cursor:pointer;margin-bottom:1rem;background:none;border:none;padding:0; }
    .back-link:hover { color:var(--primary); }
    .divider-text { text-align:center; color:var(--gray-400); font-size:.8rem; margin:.5rem 0; }
  </style>
</head>
<body>
  <div class="auth-wrap">
    <div class="auth-card">
      <div class="auth-logo">
        <a href="/"><img src="/logo.png" alt="MyPA"
           style="width:80px;height:80px;border-radius:50%;object-fit:cover;margin-bottom:.75rem;cursor:pointer;transition:transform .2s;"
           onmouseover="this.style.transform='scale(1.08)'" onmouseout="this.style.transform='scale(1)'"></a>
        <h1>MyPA</h1>
        <p>Welcome back · Simply Assist</p>
      </div>

      <% if (error) { %>
        <div class="alert alert-danger">⚠️ <%= error %></div>
      <% } %>

      <!-- Role selector -->
      <div id="roleSelector">
        <p style="text-align:center;font-size:.85rem;color:var(--gray-400);margin-bottom:1rem;font-weight:600;text-transform:uppercase;letter-spacing:.05em;">Select Login Type</p>
        <div class="role-grid">
          <a class="role-btn admin-btn" onclick="showLogin('admin')" href="javascript:void(0)">
            <span class="icon">🛠️</span>
            <span class="label">Admin</span>
            <span class="sub">Full access</span>
          </a>
          <a class="role-btn shop-btn" onclick="showLogin('shopkeeper')" href="javascript:void(0)">
            <span class="icon">🏪</span>
            <span class="label">Shopkeeper</span>
            <span class="sub">Business account</span>
          </a>
          <a class="role-btn indiv-btn" onclick="showLogin('individual')" href="javascript:void(0)">
            <span class="icon">👤</span>
            <span class="label">Individual</span>
            <span class="sub">Personal account</span>
          </a>
          <a class="role-btn cust-btn" href="/customer-login">
            <span class="icon">🛒</span>
            <span class="label">Customer</span>
            <span class="sub">View my account</span>
          </a>
        </div>
        <p style="text-align:center;margin-top:.75rem;font-size:.85rem;color:#6b7280;">
          No account? <a href="/register" style="color:var(--primary);font-weight:600;">Register free</a>
        </p>
      </div>

      <!-- Login form (hidden until role selected) -->
      <div id="loginFormWrap" class="login-form">
        <button class="back-link" onclick="backToRoles()">← Back</button>
        <p id="loginRoleLabel" style="text-align:center;font-weight:700;font-size:.95rem;margin-bottom:1.25rem;color:var(--primary);"></p>

        <form action="/login" method="POST">
          <div class="form-group">
            <label class="form-label">Email Address</label>
            <input type="email" class="form-control" name="email" required placeholder="you@email.com" autofocus>
          </div>
          <div class="form-group">
            <label class="form-label">Password</label>
            <input type="password" class="form-control" name="password" required placeholder="Your password">
          </div>
          <button type="submit" class="btn btn-primary btn-block" id="loginSubmitBtn">Sign In →</button>
        </form>
      </div>

    </div>
  </div>

  <script>
    var roleLabels = {
      admin:      { label: '🛠️ Admin Login',       color: '#dc2626' },
      shopkeeper: { label: '🏪 Shopkeeper Login',  color: '#ca8a04' },
      individual: { label: '👤 Individual Login',  color: '#2563eb' }
    };

    function showLogin(role) {
      document.getElementById('roleSelector').style.display = 'none';
      document.getElementById('loginFormWrap').classList.add('show');
      var cfg = roleLabels[role];
      var lbl = document.getElementById('loginRoleLabel');
      lbl.textContent = cfg.label;
      lbl.style.color = cfg.color;
      document.getElementById('loginSubmitBtn').style.background  = cfg.color;
      document.getElementById('loginSubmitBtn').style.borderColor = cfg.color;
    }

    function backToRoles() {
      document.getElementById('roleSelector').style.display = 'block';
      document.getElementById('loginFormWrap').classList.remove('show');
    }
  </script>
</body>
</html>
