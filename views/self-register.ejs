<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Register at <%= business.business_name %> – MyPA</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body style="background:linear-gradient(135deg,var(--primary-light) 0%,#f0fdf4 100%);min-height:100vh;padding:2rem 1rem;">
  <div style="max-width:460px;margin:0 auto;">

    <!-- Shop branding -->
    <div style="text-align:center;margin-bottom:2rem;">
      <% if (business.business_logo) { %>
        <img src="<%= business.business_logo %>" width="70" height="70" style="border-radius:14px;margin-bottom:.75rem;">
      <% } else { %>
        <div style="font-size:3rem;margin-bottom:.5rem;">🏪</div>
      <% } %>
      <h2 style="font-size:1.4rem;font-weight:800;color:var(--gray-900);"><%= business.business_name %></h2>
      <p style="color:var(--gray-500);font-size:.9rem;"><%= business.business_type %></p>
    </div>

    <div class="auth-card">
      <div class="auth-logo">
        <h1 style="font-size:1.4rem;">Register for Credit</h1>
        <p>Fill in your details to register at this shop</p>
      </div>

      <% if (error) { %>
        <div class="alert alert-danger">⚠️ <%= error %></div>
      <% } %>
      <% if (success) { %>
        <div class="alert alert-success">✅ <%= success %></div>
        <div style="text-align:center;margin-top:1rem;">
          <p class="text-muted text-sm">You can now make credit purchases at this shop. The shopkeeper has been notified.</p>
        </div>
      <% } else { %>
      <form action="/register-credit" method="POST">
        <input type="hidden" name="shop_id" value="<%= business.business_id %>">

        <div class="form-group">
          <label class="form-label">Full Name <span class="required">*</span></label>
          <input type="text" class="form-control" name="name" required placeholder="Your full name" autofocus>
        </div>
        <div class="form-group">
          <label class="form-label">Mobile Number <span class="required">*</span></label>
          <input type="tel" class="form-control" name="mobile" required placeholder="10-digit mobile number" pattern="[0-9]{10}">
        </div>
        <div class="form-group">
          <label class="form-label">Address</label>
          <input type="text" class="form-control" name="address" placeholder="Your address (optional)">
        </div>
        <button type="submit" class="btn btn-primary btn-block" style="margin-top:.5rem;">✅ Register for Credit</button>
      </form>
      <% } %>
    </div>

    <p style="text-align:center;margin-top:1.5rem;font-size:.8rem;color:var(--gray-400);">
      Powered by <img src="/logo.png" style="width:18px;height:18px;border-radius:50%;vertical-align:middle;"> <strong style="color:var(--primary);">MyPA</strong> · Simply Assist
    </p>
  </div>
</body>
</html>
