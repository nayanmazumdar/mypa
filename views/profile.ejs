<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Profile – MyPA</title>
  <link rel="icon" type="image/png" href="/logo.png">
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <%- include('partials/navbar') %>
  <div class="container">

    <% if (success) { %><div class="alert alert-success">✅ <%= success %></div><% } %>
    <% if (error) { %><div class="alert alert-danger">⚠️ <%= error %></div><% } %>

    <!-- Profile header -->
    <div class="profile-header">
      <% if (user.profile_photo) { %>
        <img src="<%= user.profile_photo %>" class="avatar" width="90" height="90" alt="Photo">
      <% } else { %>
        <div class="avatar-placeholder" style="width:90px;height:90px;font-size:2.2rem;border:3px solid rgba(255,255,255,.4)"><%= user.name.charAt(0).toUpperCase() %></div>
      <% } %>
      <div class="profile-header-info">
        <h2><%= user.name %></h2>
        <p><%= user.email %> · 📞 <%= user.mobile %></p>
        <p style="margin-top:.35rem;">
          <span style="background:rgba(255,255,255,.2);border-radius:6px;padding:.2rem .6rem;font-size:.8rem;text-transform:capitalize;"><%= user.role %></span>
          <span style="margin-left:.5rem;font-size:.85rem;opacity:.8;">Member since <%= new Date(user.created_at).toLocaleDateString('en-IN',{month:'long',year:'numeric'}) %></span>
        </p>
      </div>
      <div style="margin-left:auto;text-align:right;">
        <div style="font-size:2rem;font-weight:800;"><%= completeness.score %>%</div>
        <div style="font-size:.8rem;opacity:.8;">Profile Complete</div>
        <div style="background:rgba(255,255,255,.2);border-radius:999px;height:6px;width:100px;margin-top:.4rem;">
          <div style="background:#fff;height:6px;border-radius:999px;width:<%= completeness.score %>%;"></div>
        </div>
      </div>
    </div>

    <form action="/profile" method="POST" enctype="multipart/form-data">
      <div class="grid grid-2">

        <!-- Personal Info -->
        <div class="card">
          <div class="card-header"><h2>👤 Personal Information</h2></div>
          <div class="card-body">
            <div class="form-section-title">Mandatory</div>
            <div class="form-group">
              <label class="form-label">Full Name <span class="required">*</span></label>
              <input type="text" class="form-control" name="name" value="<%= user.name %>" required>
            </div>
            <div class="form-group">
              <label class="form-label">Mobile Number <span class="required">*</span></label>
              <input type="tel" class="form-control" name="mobile" value="<%= user.mobile %>" required>
            </div>

            <div class="form-section-title" style="margin-top:1.5rem;">Optional</div>
            <div class="grid grid-2">
              <div class="form-group">
                <label class="form-label">Date of Birth</label>
                <input type="date" class="form-control" name="date_of_birth" value="<%= user.date_of_birth || '' %>">
              </div>
              <div class="form-group">
                <label class="form-label">Gender</label>
                <select class="form-control" name="gender">
                  <option value="">Select</option>
                  <% ['male','female','other','prefer_not_to_say'].forEach(g => { %>
                    <option value="<%=g%>" <%=user.gender===g?'selected':''%>><%= g.replace(/_/g,' ') %></option>
                  <% }) %>
                </select>
              </div>
            </div>
            <div class="form-group">
              <label class="form-label">Occupation</label>
              <input type="text" class="form-control" name="occupation" value="<%= user.occupation || '' %>" placeholder="Your occupation">
            </div>
            <div class="form-group">
              <label class="form-label">Address</label>
              <input type="text" class="form-control" name="address" value="<%= user.address || '' %>" placeholder="Street address">
            </div>
            <div class="grid grid-2">
              <div class="form-group">
                <label class="form-label">City</label>
                <input type="text" class="form-control" name="city" value="<%= user.city || '' %>">
              </div>
              <div class="form-group">
                <label class="form-label">State</label>
                <input type="text" class="form-control" name="state" value="<%= user.state || '' %>">
              </div>
            </div>
            <div class="grid grid-2">
              <div class="form-group">
                <label class="form-label">Country</label>
                <input type="text" class="form-control" name="country" value="<%= user.country || 'India' %>">
              </div>
              <div class="form-group">
                <label class="form-label">Pincode</label>
                <input type="text" class="form-control" name="pincode" value="<%= user.pincode || '' %>">
              </div>
            </div>
            <div class="form-group">
              <label class="form-label">Emergency Contact</label>
              <input type="tel" class="form-control" name="emergency_contact" value="<%= user.emergency_contact || '' %>">
            </div>
            <div class="grid grid-2">
              <div class="form-group">
                <label class="form-label">Preferred Language</label>
                <select class="form-control" name="preferred_language">
                  <option value="">Select</option>
                  <% ['English','Hindi','Gujarati','Marathi','Tamil','Telugu','Kannada','Bengali','Other'].forEach(l=>{ %>
                    <option value="<%=l%>" <%=user.preferred_language===l?'selected':''%>><%=l%></option>
                  <% }) %>
                </select>
              </div>
              <div class="form-group">
                <label class="form-label">Marital Status</label>
                <select class="form-control" name="marital_status">
                  <option value="">Select</option>
                  <% ['Single','Married','Divorced','Widowed'].forEach(m=>{ %>
                    <option value="<%=m%>" <%=user.marital_status===m?'selected':''%>><%=m%></option>
                  <% }) %>
                </select>
              </div>
            </div>
          </div>
        </div>

        <div style="display:flex;flex-direction:column;gap:1.5rem;">
          <!-- Profile photo -->
          <div class="card">
            <div class="card-header"><h2>📷 Profile Photo</h2></div>
            <div class="card-body" style="text-align:center;">
              <% if (user.profile_photo) { %>
                <img src="<%= user.profile_photo %>" width="100" height="100" class="avatar" style="margin-bottom:1rem;">
              <% } else { %>
                <div class="avatar-placeholder" style="width:100px;height:100px;font-size:2.5rem;margin:0 auto 1rem;">👤</div>
              <% } %>
              <input type="file" class="form-control" name="profile_photo" accept="image/jpeg,image/png,image/webp">
              <p class="form-hint">JPG, PNG, WEBP · Max 5 MB</p>
            </div>
          </div>

          <!-- Completeness -->
          <div class="card">
            <div class="card-header"><h2>📊 Completeness</h2></div>
            <div class="card-body">
              <div class="progress-wrap">
                <div class="progress-label"><span>Profile</span><span><%= completeness.score %>%</span></div>
                <div class="progress-bar-bg"><div class="progress-bar-fill" style="width:<%= completeness.score %>%"></div></div>
              </div>
              <% if (completeness.missing.length > 0) { %>
                <p class="text-sm text-muted" style="margin-top:.75rem;margin-bottom:.5rem;">Missing fields:</p>
                <% completeness.missing.forEach(f => { %><span class="tag">+ <%= f.replace(/_/g,' ') %></span><% }) %>
              <% } else { %>
                <p class="text-sm" style="color:var(--success);">✅ Profile complete!</p>
              <% } %>
            </div>
          </div>

          <!-- Business profile (shopkeeper only) -->
          <% if (user.role === 'shopkeeper' && business) { %>
          <div class="card">
            <div class="card-header" style="display:flex;justify-content:space-between;align-items:center;">
              <h2>🏪 Business Profile</h2>
              <a href="/business/card" target="_blank" class="btn btn-secondary btn-sm">🪪 Print Business Card</a>
            </div>
            <div class="card-body">
              <div class="form-group">
                <label class="form-label">Business Name <span class="required">*</span></label>
                <input type="text" class="form-control" name="business_name" value="<%= business.business_name %>" required>
              </div>
              <div class="form-group">
                <label class="form-label">Business Type</label>
                <select class="form-control" name="business_type">
                  <% ['Grocery Store','Pharmacy','Stationery Shop','Hardware Store','Bakery','Tea Stall','Restaurant','Electronics Shop','Clothing Store','Mobile Shop','Other'].forEach(c=>{ %>
                    <option value="<%=c%>" <%=business.business_type===c?'selected':''%>><%=c%></option>
                  <% }) %>
                </select>
              </div>
              <div class="form-group">
                <label class="form-label">GST Number</label>
                <input type="text" class="form-control" name="gst_number" value="<%= business.gst_number || '' %>">
              </div>
              <div class="form-group">
                <label class="form-label">Trade License No.</label>
                <input type="text" class="form-control" name="license_number" value="<%= business.license_number || '' %>">
              </div>
              <div class="form-group">
                <label class="form-label">Business Address</label>
                <input type="text" class="form-control" name="business_address" value="<%= business.address || '' %>">
              </div>
              <div class="form-group">
                <label class="form-label">Description</label>
                <textarea class="form-control" name="description" rows="2"><%= business.description || '' %></textarea>
              </div>
              <div class="form-group">
                <label class="form-label">Website</label>
                <input type="url" class="form-control" name="website" value="<%= business.website || '' %>" placeholder="https://...">
              </div>
              <div class="form-group">
                <label class="form-label">Business Logo</label>
                <% if (business.business_logo) { %>
                  <img src="<%= business.business_logo %>" width="60" height="60" style="border-radius:8px;display:block;margin-bottom:.5rem;">
                <% } %>
                <input type="file" class="form-control" name="business_logo" accept="image/jpeg,image/png,image/webp">
              </div>
            </div>
          </div>
          <% } %>
        </div>
      </div>

      <div style="margin-top:1.5rem;text-align:right;">
        <button type="submit" class="btn btn-primary" style="padding:.75rem 2rem;">💾 Save Profile</button>
      </div>
    </form>
  </div>
</body>
</html>
