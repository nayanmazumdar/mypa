<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Panel – MyPA</title>
  <link rel="icon" type="image/png" href="/logo.png">
  <link rel="stylesheet" href="/style.css">
  <style>
    .admin-tabs{display:flex;gap:.5rem;flex-wrap:wrap;margin-bottom:1.5rem;border-bottom:2px solid var(--gray-200);padding-bottom:.75rem;}
    .tab-btn{padding:.5rem 1.1rem;border-radius:8px 8px 0 0;border:1px solid var(--gray-200);border-bottom:none;background:#fff;cursor:pointer;font-weight:600;font-size:.875rem;color:var(--gray-400);transition:all .15s;}
    .tab-btn.active{background:var(--primary);color:#fff;border-color:var(--primary);}
    .tab-btn:hover:not(.active){background:var(--gray-50);color:var(--gray-700);}
    .tab-pane{display:none;} .tab-pane.active{display:block;}
    .modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:1000;align-items:center;justify-content:center;}
    .modal-overlay.open{display:flex;}
    .modal-box{background:#fff;border-radius:14px;padding:2rem;width:100%;max-width:460px;max-height:90vh;overflow-y:auto;box-shadow:0 20px 60px rgba(0,0,0,.2);}
    .modal-box h3{margin:0 0 1rem;font-size:1.1rem;}
    .modal-close{float:right;background:none;border:none;font-size:1.3rem;cursor:pointer;color:var(--gray-400);}
    .modal-close:hover{color:var(--danger);}
    .btn-xs{padding:.25rem .6rem;font-size:.75rem;border-radius:6px;border:none;cursor:pointer;font-weight:600;line-height:1.6;}
    .btn-xs-edit{background:#eff6ff;color:#2563eb;} .btn-xs-edit:hover{background:#dbeafe;}
    .btn-xs-del{background:#fff1f2;color:#e11d48;} .btn-xs-del:hover{background:#ffe4e6;}
    .btn-xs-pwd{background:#f0fdf4;color:#16a34a;} .btn-xs-pwd:hover{background:#dcfce7;}
    .btn-xs-sub{background:#faf5ff;color:#7c3aed;} .btn-xs-sub:hover{background:#ede9fe;}
    .action-btns{display:flex;gap:.4rem;flex-wrap:wrap;align-items:center;}
    .search-bar{margin-bottom:1rem;}
    .search-bar input{width:100%;padding:.5rem .85rem;border:1px solid var(--gray-200);border-radius:8px;font-size:.875rem;outline:none;}
    .search-bar input:focus{border-color:var(--primary);}
    .flash{padding:.75rem 1rem;border-radius:8px;margin-bottom:1.25rem;font-weight:600;background:#f0fdf4;color:#15803d;border:1px solid #bbf7d0;}
    .badge-danger{background:#fee2e2;color:#dc2626;}
    .sdot{display:inline-block;width:8px;height:8px;border-radius:50%;margin-right:3px;vertical-align:middle;}
    .sdot-on{background:#16a34a;} .sdot-off{background:#dc2626;}
    .exp-ok{color:#16a34a;font-size:.72rem;font-weight:600;}
    .exp-warn{color:#f59e0b;font-size:.72rem;font-weight:600;}
    .exp-over{color:#dc2626;font-size:.72rem;font-weight:600;}
    .divider{border:none;border-top:1px solid var(--gray-200);margin:1rem 0;}
  </style>
</head>
<body>
  <%- include('partials/navbar') %>
  <div class="container">
    <div class="flex-between page-header" style="margin-bottom:1rem;">
      <div><h1>🛠️ Welcome, <%= user.name %></h1><p>Full Privilege</p></div>
    </div>
    <% if (typeof msg !== 'undefined' && msg) { %>
      <div class="flash" id="flashMsg">✅ <%= msg %></div>
    <% } %>

    <%
      var today = new Date().toISOString().slice(0,10);
      var expiredUsers = users.filter(function(u){ return u.active_until && u.active_until <= today && u.role !== 'admin'; });
      var expiredBiz   = businesses.filter(function(b){ return b.active_until && b.active_until <= today; });
      var expiredCust  = customers.filter(function(c){ return c.active_until && c.active_until <= today; });
      var totalExpired = expiredUsers.length + expiredBiz.length + expiredCust.length;
    %>
    <% if (totalExpired > 0) { %>
    <div style="background:#fff1f2;border:1.5px solid #fca5a5;border-radius:10px;padding:1rem 1.25rem;margin-bottom:1.25rem;">
      <div style="display:flex;align-items:flex-start;gap:.75rem;">
        <span style="font-size:1.4rem;line-height:1;">🚨</span>
        <div style="flex:1;">
          <div style="font-weight:700;color:#dc2626;font-size:.95rem;margin-bottom:.5rem;">
            <%= totalExpired %> account<%= totalExpired>1?'s':'' %> expired or expiring today
          </div>
          <% if (expiredUsers.length > 0) { %>
          <div style="margin-bottom:.35rem;">
            <span style="font-weight:600;color:#b91c1c;font-size:.82rem;">👤 Users:</span>
            <% expiredUsers.forEach(function(u){ %>
              <span style="display:inline-block;background:#fee2e2;color:#dc2626;padding:.15rem .55rem;border-radius:20px;font-size:.75rem;font-weight:600;margin:.1rem .2rem;">
                <%= u.name %> (<%= u.active_until %>)
              </span>
            <% }) %>
          </div>
          <% } %>
          <% if (expiredBiz.length > 0) { %>
          <div style="margin-bottom:.35rem;">
            <span style="font-weight:600;color:#b91c1c;font-size:.82rem;">🏪 Businesses:</span>
            <% expiredBiz.forEach(function(b){ %>
              <span style="display:inline-block;background:#fee2e2;color:#dc2626;padding:.15rem .55rem;border-radius:20px;font-size:.75rem;font-weight:600;margin:.1rem .2rem;">
                <%= b.business_name %> (<%= b.active_until %>)
              </span>
            <% }) %>
          </div>
          <% } %>
          <% if (expiredCust.length > 0) { %>
          <div>
            <span style="font-weight:600;color:#b91c1c;font-size:.82rem;">👥 Customers:</span>
            <% expiredCust.forEach(function(c){ %>
              <span style="display:inline-block;background:#fee2e2;color:#dc2626;padding:.15rem .55rem;border-radius:20px;font-size:.75rem;font-weight:600;margin:.1rem .2rem;">
                <%= c.name %> (<%= c.active_until %>)
              </span>
            <% }) %>
          </div>
          <% } %>
        </div>
      </div>
    </div>
    <% } %>
    <!-- Stats -->
    <div class="grid grid-4" style="margin-bottom:1.75rem;">
      <div class="stat-card"><div class="stat-icon indigo">👤</div><div class="stat-info"><p>Users</p><h3><%= users.length %></h3></div></div>
      <div class="stat-card"><div class="stat-icon cyan">🏪</div><div class="stat-info"><p>Businesses</p><h3><%= businesses.length %></h3></div></div>
      <div class="stat-card"><div class="stat-icon amber">👥</div><div class="stat-info"><p>Customers</p><h3><%= customers.length %></h3></div></div>
      <div class="stat-card"><div class="stat-icon green">💳</div><div class="stat-info"><p>Transactions</p><h3><%= transactions.length %></h3></div></div>
    </div>
    <!-- Tabs -->
    <div class="admin-tabs">
      <button class="tab-btn active" onclick="showTab('users',this)">👤 Users (<%= users.length %>)</button>
      <button class="tab-btn" onclick="showTab('businesses',this)">🏪 Businesses (<%= businesses.length %>)</button>
      <button class="tab-btn" onclick="showTab('customers',this)">👥 Customers (<%= customers.length %>)</button>
      <button class="tab-btn" onclick="showTab('transactions',this)">💳 Transactions (<%= transactions.length %>)</button>
      <button class="tab-btn" onclick="showTab('notes',this)">📝 Notes (<%= notes.length %>)</button>
      <button class="tab-btn" onclick="showTab('documents',this)">📄 Documents (<%= documents.length %>)</button>
      <button class="tab-btn" onclick="showTab('subscriptions',this)">🔐 Subscriptions (<%= subscriptions.length %>)</button>
      <button class="tab-btn" onclick="showTab('myprofile',this)">⚙️ My Profile</button>
    </div>

    <!-- ═══ USERS ═══ -->
    <div class="tab-pane active" id="tab-users">
      <div class="card">
        <div class="card-header"><h2>👤 Users</h2></div>
        <div class="card-body" style="padding-bottom:0;">
          <div class="search-bar"><input type="text" placeholder="🔍 Search name, email, mobile…" oninput="filterTable('tbl-users',this.value)"></div>
        </div>
        <div class="table-wrap">
          <table id="tbl-users">
            <thead><tr><th>#</th><th>Name</th><th>Mobile</th><th>Email</th><th>Role</th><th>Status</th><th>Expires</th><th>City</th><th>Registered</th><th>Actions</th></tr></thead>
            <tbody>
              <% var today=new Date().toISOString().slice(0,10); %>
              <% users.forEach(function(u,i){ var ec=!u.active_until?'':u.active_until<today?'exp-over':u.active_until<=new Date(Date.now()+7*864e5).toISOString().slice(0,10)?'exp-warn':'exp-ok'; %>
              <tr>
                <td class="text-muted text-sm"><%= i+1 %></td>
                <td class="fw-bold"><%= u.name %></td>
                <td><%= u.mobile %></td>
                <td><%= u.email %></td>
                <td><span class="badge <%= u.role==='admin'?'badge-danger':u.role==='shopkeeper'?'badge-gold':'badge-navy' %>"><%= u.role %></span></td>
                <td><span class="sdot <%= u.is_active!==0?'sdot-on':'sdot-off' %>"></span><%= u.is_active!==0?'Active':'Inactive' %></td>
                <td><% if(u.active_until){%><span class="<%= ec %>"><%= u.active_until %></span><%}else{%><span class="text-muted text-sm">—</span><%}%></td>
                <td><%= u.city||'—' %></td>
                <td class="text-sm text-muted"><%= new Date(u.created_at).toLocaleDateString('en-IN') %></td>
                <td>
                  <div class="action-btns">
                    <button class="btn-xs btn-xs-edit" data-id="<%= u.user_id %>" data-name="<%= u.name %>" data-mobile="<%= u.mobile %>" data-email="<%= u.email %>" data-role="<%= u.role %>" data-city="<%= u.city||'' %>" data-occupation="<%= u.occupation||'' %>" onclick="openEditUser(this)">✏️ Edit</button>
                    <button class="btn-xs btn-xs-pwd" data-id="<%= u.user_id %>" data-name="<%= u.name %>" onclick="openResetPwd(this)">🔑 Pwd</button>
                    <% if(u.role !== 'admin') { %>
                    <button class="btn-xs btn-xs-sub" data-id="<%= u.user_id %>" data-name="<%= u.name %>" data-type="user" data-active="<%= u.is_active!==0?1:0 %>" data-until="<%= u.active_until||'' %>" onclick="openSubModal(this)">🔐 Subscription</button>
                    <% } %>
                    <% if(u.user_id!==user.user_id){%>
                    <form method="POST" action="/admin/users/<%= u.user_id %>/delete" style="display:inline;" class="del-form">
                      <button type="submit" class="btn-xs btn-xs-del" data-confirm="Delete user and ALL their data permanently?">🗑</button>
                    </form>
                    <%}%>
                  </div>
                </td>
              </tr>
              <%})%>
              <%if(users.length===0){%><tr><td colspan="10" class="text-center text-muted" style="padding:2rem;">No users</td></tr><%}%>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- ═══ BUSINESSES ═══ -->
    <div class="tab-pane" id="tab-businesses">
      <div class="card">
        <div class="card-header"><h2>🏪 Business Profiles</h2></div>
        <div class="card-body" style="padding-bottom:0;">
          <div class="search-bar"><input type="text" placeholder="🔍 Search businesses…" oninput="filterTable('tbl-biz',this.value)"></div>
        </div>
        <div class="table-wrap">
          <table id="tbl-biz">
            <thead><tr><th>#</th><th>Business Name</th><th>Owner</th><th>Type</th><th>GST</th><th>Status</th><th>Expires</th><th>Created</th><th>Actions</th></tr></thead>
            <tbody>
              <%businesses.forEach(function(b,i){var ec=!b.active_until?'':b.active_until<today?'exp-over':b.active_until<=new Date(Date.now()+7*864e5).toISOString().slice(0,10)?'exp-warn':'exp-ok';%>
              <tr>
                <td class="text-muted text-sm"><%= i+1 %></td>
                <td class="fw-bold"><%= b.business_name %></td>
                <td><%= b.owner_name||'—' %></td>
                <td><span class="badge badge-gold"><%= b.business_type||'—' %></span></td>
                <td class="text-sm"><%= b.gst_number||'—' %></td>
                <td><span class="sdot <%= b.is_active!==0?'sdot-on':'sdot-off' %>"></span><%= b.is_active!==0?'Active':'Inactive' %></td>
                <td><%if(b.active_until){%><span class="<%= ec %>"><%= b.active_until %></span><%}else{%><span class="text-muted text-sm">—</span><%}%></td>
                <td class="text-sm text-muted"><%= new Date(b.created_at).toLocaleDateString('en-IN') %></td>
                <td>
                  <div class="action-btns">
                    <button class="btn-xs btn-xs-sub" data-id="<%= b.business_id %>" data-name="<%= b.business_name %>" data-type="business" data-active="<%= b.is_active!==0?1:0 %>" data-until="<%= b.active_until||'' %>" onclick="openSubModal(this)">🔐 Subscription</button>
                  </div>
                </td>
              </tr>
              <%})%>
              <%if(businesses.length===0){%><tr><td colspan="9" class="text-center text-muted" style="padding:2rem;">No businesses</td></tr><%}%>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- ═══ CUSTOMERS ═══ -->
    <div class="tab-pane" id="tab-customers">
      <%var bizMap={};businesses.forEach(function(b){bizMap[b.business_id]=b;});%>
      <div class="card">
        <div class="card-header"><h2>👥 Customers</h2></div>
        <div class="card-body" style="padding-bottom:0;">
          <div class="search-bar"><input type="text" placeholder="🔍 Search customers, shop…" oninput="filterTable('tbl-cust',this.value)"></div>
        </div>
        <div class="table-wrap">
          <table id="tbl-cust">
            <thead><tr><th>#</th><th>Name</th><th>Address</th><th>Shop</th><th>Due</th><th>Status</th><th>Expires</th><th>Added</th><th>Actions</th></tr></thead>
            <tbody>
              <%customers.forEach(function(c,i){var biz=bizMap[c.business_id]||null;var ec=!c.active_until?'':c.active_until<today?'exp-over':c.active_until<=new Date(Date.now()+7*864e5).toISOString().slice(0,10)?'exp-warn':'exp-ok';%>
              <tr>
                <td class="text-muted text-sm"><%= i+1 %></td>
                <td class="fw-bold"><%= c.name %><br><span class="text-muted text-sm"><%= c.mobile %></span></td>
                <td><%= c.address||'—' %></td>
                <td><%if(biz){%><div class="fw-bold" style="font-size:.82rem;"><%= biz.business_name %></div><%}else{%>—<%}%></td>
                <td style="font-weight:700;color:<%= c.current_balance>0?'var(--danger)':'var(--success)' %>;">₹<%= (c.current_balance||0).toLocaleString('en-IN') %></td>
                <td><span class="sdot <%= c.is_active!==0?'sdot-on':'sdot-off' %>"></span><span class="badge <%= c.status==='active'?'badge-success':'badge-warning' %>"><%= c.status %></span></td>
                <td><%if(c.active_until){%><span class="<%= ec %>"><%= c.active_until %></span><%}else{%><span class="text-muted text-sm">—</span><%}%></td>
                <td class="text-sm text-muted"><%= new Date(c.created_at).toLocaleDateString('en-IN') %></td>
                <td>
                  <div class="action-btns">
                    <button class="btn-xs btn-xs-sub" data-id="<%= c.customer_id %>" data-name="<%= c.name %>" data-type="customer" data-active="<%= c.is_active!==0?1:0 %>" data-until="<%= c.active_until||'' %>" onclick="openSubModal(this)">🔐 Subscription</button>
                    <button class="btn-xs btn-xs-pwd" data-id="<%= c.customer_id %>" data-name="<%= c.name %>" onclick="openCustPwd(this)">🔑 Set Password</button>
                    <form method="POST" action="/admin/customers/<%= c.customer_id %>/delete" style="display:inline;" class="del-form">
                      <button type="submit" class="btn-xs btn-xs-del" data-confirm="Delete customer and all their data?">🗑</button>
                    </form>
                  </div>
                </td>
              </tr>
              <%})%>
              <%if(customers.length===0){%><tr><td colspan="9" class="text-center text-muted" style="padding:2rem;">No customers</td></tr><%}%>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- ═══ TRANSACTIONS ═══ -->
    <div class="tab-pane" id="tab-transactions">
      <div class="card">
        <div class="card-header"><h2>💳 Credit Transactions</h2></div>
        <div class="card-body" style="padding-bottom:0;"><div class="search-bar"><input type="text" placeholder="🔍 Search…" oninput="filterTable('tbl-txn',this.value)"></div></div>
        <div class="table-wrap">
          <table id="tbl-txn">
            <thead><tr><th>#</th><th>Date</th><th>Customer</th><th>Type</th><th>Amount</th><th>Note</th><th>Recorded</th><th>Actions</th></tr></thead>
            <tbody>
              <%var custMap2={};customers.forEach(function(c){custMap2[c.customer_id]=c;});%>
              <%transactions.forEach(function(t,i){var cn=custMap2[t.customer_id];%>
              <tr>
                <td class="text-muted text-sm"><%= i+1 %></td>
                <td><%= new Date(t.date).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) %></td>
                <td class="text-sm"><%= cn?cn.name:t.customer_id %></td>
                <td><%if(t.type==='sale_credit'||t.type==='sale'){%><span style="background:#fff3f3;color:var(--danger);padding:.2rem .5rem;border-radius:20px;font-size:.72rem;font-weight:700;">🛒 Sale/Credit</span><%}else{%><span style="background:#f0fdf4;color:var(--success);padding:.2rem .5rem;border-radius:20px;font-size:.72rem;font-weight:700;">💰 Payment</span><%}%></td>
                <td style="font-weight:700;color:<%= (t.type==='sale_credit'||t.type==='sale')?'var(--danger)':'var(--success)' %>;"><%= (t.type==='sale_credit'||t.type==='sale')?'+':'-' %>₹<%= t.amount.toLocaleString('en-IN') %></td>
                <td class="text-sm text-muted"><%= t.note||'—' %></td>
                <td class="text-sm text-muted"><%= new Date(t.created_at).toLocaleDateString('en-IN') %></td>
                <td><form method="POST" action="/admin/transactions/<%= t.txn_id %>/delete" style="display:inline;" class="del-form"><button type="submit" class="btn-xs btn-xs-del" data-confirm="Delete transaction? Balance will be recalculated.">🗑</button></form></td>
              </tr>
              <%})%>
              <%if(transactions.length===0){%><tr><td colspan="8" class="text-center text-muted" style="padding:2rem;">No transactions</td></tr><%}%>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- ═══ NOTES ═══ -->
    <div class="tab-pane" id="tab-notes">
      <%var custMap3={};customers.forEach(function(c){custMap3[c.customer_id]=c;});var bizMap3={};businesses.forEach(function(b){bizMap3[b.business_id]=b;});%>
      <div class="card">
        <div class="card-header"><h2>📝 Customer Notes</h2></div>
        <div class="card-body" style="padding-bottom:0;"><div class="search-bar"><input type="text" placeholder="🔍 Search notes…" oninput="filterTable('tbl-notes',this.value)"></div></div>
        <div class="table-wrap">
          <table id="tbl-notes">
            <thead><tr><th>#</th><th>Customer</th><th>Business</th><th>Note</th><th>Added</th><th>Actions</th></tr></thead>
            <tbody>
              <%notes.forEach(function(n,i){var cust=custMap3[n.customer_id]||null;var biz2=cust?(bizMap3[cust.business_id]||null):null;%>
              <tr>
                <td class="text-muted text-sm"><%= i+1 %></td>
                <td><%if(cust){%><div class="fw-bold" style="font-size:.875rem;"><%= cust.name %></div><div class="text-muted text-sm">📞 <%= cust.mobile %></div><%}else{%><span class="text-muted text-sm"><%= n.customer_id %></span><%}%></td>
                <td><%if(biz2){%><div class="fw-bold" style="font-size:.875rem;"><%= biz2.business_name %></div><%}else{%>—<%}%></td>
                <td><%= n.text %></td>
                <td class="text-sm text-muted"><%= new Date(n.created_at).toLocaleDateString('en-IN') %></td>
                <td><form method="POST" action="/admin/notes/<%= n.note_id %>/delete" style="display:inline;" class="del-form"><button type="submit" class="btn-xs btn-xs-del" data-confirm="Delete this note?">🗑</button></form></td>
              </tr>
              <%})%>
              <%if(notes.length===0){%><tr><td colspan="6" class="text-center text-muted" style="padding:2rem;">No notes</td></tr><%}%>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- ═══ DOCUMENTS ═══ -->
    <div class="tab-pane" id="tab-documents">
      <%var userMap={};users.forEach(function(u){userMap[u.user_id]=u;});var bizByUser={};businesses.forEach(function(b){bizByUser[b.user_id]=b;});%>
      <div class="card">
        <div class="card-header"><h2>📄 Documents</h2></div>
        <div class="card-body" style="padding-bottom:0;"><div class="search-bar"><input type="text" placeholder="🔍 Search documents…" oninput="filterTable('tbl-docs',this.value)"></div></div>
        <div class="table-wrap">
          <table id="tbl-docs">
            <thead><tr><th>#</th><th>Owner</th><th>Business</th><th>File</th><th>Type</th><th>Uploaded</th><th>Actions</th></tr></thead>
            <tbody>
              <%documents.forEach(function(d,i){var owner=userMap[d.owner_user_id]||null;var biz4=owner?(bizByUser[owner.user_id]||null):null;%>
              <tr>
                <td class="text-muted text-sm"><%= i+1 %></td>
                <td><%if(owner){%><div class="fw-bold" style="font-size:.875rem;"><%= owner.name %></div><div class="text-muted text-sm"><span class="badge <%= owner.role==='shopkeeper'?'badge-gold':'badge-navy' %>" style="font-size:.7rem;"><%= owner.role %></span></div><%}else{%><span class="text-muted text-sm"><%= d.owner_user_id %></span><%}%></td>
                <td><%if(biz4){%><div class="fw-bold" style="font-size:.875rem;"><%= biz4.business_name %></div><%}else{%>—<%}%></td>
                <td class="fw-bold"><a href="<%= d.file_path %>" target="_blank" style="color:var(--primary);"><%= d.file_name %></a></td>
                <td><span class="badge badge-gold"><%= d.document_type.replace(/_/g,' ') %></span></td>
                <td class="text-sm text-muted"><%= new Date(d.uploaded_at).toLocaleDateString('en-IN') %></td>
                <td><form method="POST" action="/admin/documents/<%= d.document_id %>/delete" style="display:inline;" class="del-form"><button type="submit" class="btn-xs btn-xs-del" data-confirm="Delete document record?">🗑</button></form></td>
              </tr>
              <%})%>
              <%if(documents.length===0){%><tr><td colspan="7" class="text-center text-muted" style="padding:2rem;">No documents</td></tr><%}%>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- ═══ SUBSCRIPTIONS ═══ -->
    <div class="tab-pane" id="tab-subscriptions">
      <div class="card">
        <div class="card-header"><h2>🔐 Subscription History</h2></div>
        <div class="card-body" style="padding-bottom:0;"><div class="search-bar"><input type="text" placeholder="🔍 Search…" oninput="filterTable('tbl-subs',this.value)"></div></div>
        <div class="table-wrap">
          <table id="tbl-subs">
            <thead><tr><th>#</th><th>Entity</th><th>Name</th><th>Action</th><th>Active Until</th><th>Fee (₹)</th><th>Note</th><th>Date</th></tr></thead>
            <tbody>
              <%subscriptions.forEach(function(s,i){%>
              <tr>
                <td class="text-muted text-sm"><%= i+1 %></td>
                <td><span class="badge badge-navy" style="text-transform:capitalize;"><%= s.entity_type %></span></td>
                <td class="fw-bold"><%= s.entity_name||'—' %></td>
                <td><%var ac={activated:'badge-success',deactivated:'badge-warning',set_expiry:'badge-gold'};%><span class="badge <%= ac[s.action]||'badge-navy' %>" style="text-transform:capitalize;"><%= s.action.replace(/_/g,' ') %></span></td>
                <td class="text-sm"><%= s.active_until||'—' %></td>
                <td style="font-weight:600;color:var(--success);"><%=s.fee_amount>0?'₹'+Number(s.fee_amount).toLocaleString('en-IN'):'—'%></td>
                <td class="text-muted text-sm"><%= s.fee_note||'—' %></td>
                <td class="text-sm text-muted"><%= new Date(s.created_at).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) %></td>
              </tr>
              <%})%>
              <%if(subscriptions.length===0){%><tr><td colspan="8" class="text-center text-muted" style="padding:2rem;">No history yet</td></tr><%}%>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- ═══ MY PROFILE ═══ -->
    <div class="tab-pane" id="tab-myprofile">
      <div class="grid grid-2">
        <div class="card">
          <div class="card-header"><h2>👤 Update Profile</h2></div>
          <div class="card-body">
            <form method="POST" action="/admin/profile" enctype="multipart/form-data">
              <div class="form-group"><label class="form-label">Full Name *</label><input type="text" class="form-control" name="name" value="<%= user.name %>" required></div>
              <div class="form-group"><label class="form-label">Mobile *</label><input type="tel" class="form-control" name="mobile" value="<%= user.mobile %>" required></div>
              <div class="form-group"><label class="form-label">Email</label><input type="email" class="form-control" value="<%= user.email %>" disabled style="background:var(--gray-50);color:var(--gray-400);"></div>
              <div class="form-group"><label class="form-label">City</label><input type="text" class="form-control" name="city" value="<%= user.city||'' %>"></div>
              <div class="form-group">
                <label class="form-label">Profile Photo</label>
                <%if(user.profile_photo){%><img src="<%= user.profile_photo %>" width="60" height="60" class="avatar" style="display:block;margin-bottom:.5rem;"><%}%>
                <input type="file" class="form-control" name="profile_photo" accept="image/jpeg,image/png,image/webp">
              </div>
              <button type="submit" class="btn btn-primary btn-block">💾 Save Profile</button>
            </form>
          </div>
        </div>
        <div class="card">
          <div class="card-header"><h2>🔑 Change Password</h2></div>
          <div class="card-body">
            <form method="POST" action="/admin/change-password">
              <div class="form-group"><label class="form-label">Current Password</label><input type="password" class="form-control" name="current_password" required placeholder="Current password"></div>
              <div class="form-group"><label class="form-label">New Password</label><input type="password" class="form-control" name="new_password" minlength="6" required placeholder="Min 6 characters"></div>
              <div class="form-group"><label class="form-label">Confirm New Password</label><input type="password" class="form-control" name="confirm_password" required placeholder="Repeat new password"></div>
              <button type="submit" class="btn btn-primary btn-block">🔐 Update Password</button>
            </form>
          </div>
        </div>
      </div>
    </div>

  </div><!-- /container -->

  <!-- ── Edit User Modal ── -->
  <div class="modal-overlay" id="modalEditUser">
    <div class="modal-box">
      <button class="modal-close" onclick="closeModal('modalEditUser')">✕</button>
      <h3>✏️ Edit User</h3>
      <form method="POST" id="editUserForm">
        <div class="form-group"><label class="form-label">Full Name</label><input type="text" class="form-control" name="name" id="eu_name" required></div>
        <div class="form-group"><label class="form-label">Mobile</label><input type="tel" class="form-control" name="mobile" id="eu_mobile" required></div>
        <div class="form-group"><label class="form-label">Email</label><input type="email" class="form-control" name="email" id="eu_email" required></div>
        <div class="form-group"><label class="form-label">Role</label>
          <select class="form-control" name="role" id="eu_role">
            <option value="individual">Individual</option>
            <option value="shopkeeper">Shopkeeper</option>
            <option value="admin">Admin</option>
          </select>
        </div>
        <div class="form-group"><label class="form-label">City</label><input type="text" class="form-control" name="city" id="eu_city"></div>
        <div class="form-group"><label class="form-label">Occupation</label><input type="text" class="form-control" name="occupation" id="eu_occupation"></div>
        <button type="submit" class="btn btn-primary btn-block">Save Changes</button>
      </form>
    </div>
  </div>

  <!-- ── Reset Password Modal ── -->
  <div class="modal-overlay" id="modalResetPwd">
    <div class="modal-box">
      <button class="modal-close" onclick="closeModal('modalResetPwd')">✕</button>
      <h3>🔑 Reset Password</h3>
      <p class="text-muted text-sm" id="rp_label" style="margin-bottom:1rem;"></p>
      <form method="POST" id="resetPwdForm">
        <div class="form-group"><label class="form-label">New Password</label><input type="password" class="form-control" name="new_password" minlength="6" required placeholder="Min 6 characters"></div>
        <button type="submit" class="btn btn-primary btn-block">Reset Password</button>
      </form>
    </div>
  </div>

  <!-- ── Customer Portal Password Modal ── -->
  <div class="modal-overlay" id="modalCustPwd">
    <div class="modal-box">
      <button class="modal-close" onclick="closeModal('modalCustPwd')">✕</button>
      <h3>🔑 Set Customer Portal Password</h3>
      <p class="text-muted text-sm" id="cp_label" style="margin-bottom:1rem;"></p>
      <form method="POST" id="custPwdForm">
        <div class="form-group">
          <label class="form-label">New Password <span class="required">*</span></label>
          <input type="text" class="form-control" name="new_password" required placeholder="Min 4 characters" minlength="4">
          <p class="form-hint" style="margin-top:.3rem;">Customer will use mobile number + this password to login.</p>
        </div>
        <button type="submit" class="btn btn-primary btn-block">Set Password</button>
      </form>
    </div>
  </div>
  <div class="modal-overlay" id="modalSubscription">
    <div class="modal-box">
      <button class="modal-close" onclick="closeModal('modalSubscription')">✕</button>
      <h3 id="subModalTitle">🔐 Manage Subscription</h3>
      <div id="subModalStatus" style="padding:.5rem .75rem;background:var(--gray-50);border-radius:6px;margin-bottom:1.25rem;font-size:.85rem;"></div>

      <form method="POST" id="subActivateForm">
        <div class="form-group">
          <label class="form-label">Active Until (Expiry Date) *</label>
          <input type="date" class="form-control" name="active_until" id="subActiveUntil" required>
          <p class="form-hint" style="margin-top:.3rem;">Account auto-deactivates after this date.</p>
        </div>
        <div class="form-group"><label class="form-label">Fee Received (₹)</label><input type="number" class="form-control" name="fee_amount" min="0" step="0.01" placeholder="0.00"></div>
        <div class="form-group"><label class="form-label">Note</label><input type="text" class="form-control" name="fee_note" placeholder="e.g. Monthly renewal, Annual plan…"></div>
        <button type="submit" class="btn btn-primary btn-block">✅ Activate &amp; Set Expiry</button>
      </form>

      <hr class="divider">
      <p class="text-sm text-muted" style="margin-bottom:.75rem;">Or deactivate immediately:</p>
      <form method="POST" id="subDeactivateForm">
        <div class="form-group"><label class="form-label">Reason</label><input type="text" class="form-control" name="fee_note" placeholder="e.g. Non-payment, Suspended…"></div>
        <button type="submit" class="btn btn-danger btn-block" onclick="return confirm('Deactivate this account immediately?')">⏸ Deactivate Now</button>
      </form>
    </div>
  </div>

  <script>
    function showTab(name,btn){document.querySelectorAll('.tab-pane').forEach(p=>p.classList.remove('active'));document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));document.getElementById('tab-'+name).classList.add('active');btn.classList.add('active');}
    function filterTable(id,q){q=q.toLowerCase();document.querySelectorAll('#'+id+' tbody tr').forEach(r=>{r.style.display=r.textContent.toLowerCase().includes(q)?'':'none';});}
    function openModal(id){document.getElementById(id).classList.add('open');}
    function closeModal(id){document.getElementById(id).classList.remove('open');}
    document.querySelectorAll('.modal-overlay').forEach(m=>{m.addEventListener('click',e=>{if(e.target===m)m.classList.remove('open');});});
    document.querySelectorAll('.del-form').forEach(form=>{form.addEventListener('submit',function(e){if(!confirm(this.querySelector('[data-confirm]').dataset.confirm))e.preventDefault();});});

    function openEditUser(btn){
      document.getElementById('editUserForm').action='/admin/users/'+btn.dataset.id+'/edit';
      document.getElementById('eu_name').value=btn.dataset.name;
      document.getElementById('eu_mobile').value=btn.dataset.mobile;
      document.getElementById('eu_email').value=btn.dataset.email;
      document.getElementById('eu_role').value=btn.dataset.role;
      document.getElementById('eu_city').value=btn.dataset.city;
      document.getElementById('eu_occupation').value=btn.dataset.occupation;
      openModal('modalEditUser');
    }
    function openResetPwd(btn){
      document.getElementById('resetPwdForm').action='/admin/users/'+btn.dataset.id+'/reset-password';
      document.getElementById('rp_label').textContent='Resetting password for: '+btn.dataset.name;
      openModal('modalResetPwd');
    }
    function openCustPwd(btn){
      document.getElementById('custPwdForm').action='/admin/customers/'+btn.dataset.id+'/reset-password';
      document.getElementById('cp_label').textContent='Setting portal password for: '+btn.dataset.name+' · Login: mobile + this password';
      openModal('modalCustPwd');
    }
    function openSubModal(btn){
      var id=btn.dataset.id, name=btn.dataset.name, type=btn.dataset.type;
      var active=btn.dataset.active==='1', until=btn.dataset.until;
      document.getElementById('subModalTitle').textContent='🔐 Subscription — '+name;
      document.getElementById('subModalStatus').innerHTML=
        '<strong>'+name+'</strong> · '+(active?'<span style="color:#16a34a">✅ Active</span>':'<span style="color:#dc2626">❌ Inactive</span>')+
        (until?' · Expires: <strong>'+until+'</strong>':'');
      var base=type==='user'?'/admin/users/'+id:type==='business'?'/admin/businesses/'+id:'/admin/customers/'+id;
      document.getElementById('subActivateForm').action=base+'/activate';
      document.getElementById('subDeactivateForm').action=base+'/deactivate';
      var d=new Date(); d.setFullYear(d.getFullYear()+1);
      document.getElementById('subActiveUntil').value=until||d.toISOString().slice(0,10);
      openModal('modalSubscription');
    }

    // Auto-hide flash
    const flash=document.getElementById('flashMsg');
    if(flash) setTimeout(()=>flash.style.display='none',4000);

    // Auto-open tab from URL
    const tp=new URLSearchParams(window.location.search).get('tab');
    if(tp&&document.getElementById('tab-'+tp)){
      document.querySelectorAll('.tab-pane').forEach(p=>p.classList.remove('active'));
      document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
      document.getElementById('tab-'+tp).classList.add('active');
      document.querySelectorAll('.tab-btn').forEach(b=>{if(b.getAttribute('onclick')&&b.getAttribute('onclick').includes("'"+tp+"'"))b.classList.add('active');});
    }
  </script>
</body>
</html>
