{
  "name": "shopkeeper-app",
  "version": "1.0.0",
  "description": "Shopkeeper Management App - Frontend + Backend",
  "scripts": {
    "dev": "node start.js",
    "build": "cd frontend && npm run build",
    "start": "cd backend && node src/server.js",
    "start:prod": "NODE_ENV=production node backend/src/server.js",
    "migrate": "node backend/src/database/migrate.js",
    "seed": "node backend/src/database/seed.js",
    "seed:vegetables": "node backend/src/database/seed-vegetables.js",
    "seed:bulk": "node backend/src/database/seed-bulk.js",
    "db:setup": "node backend/src/database/migrate.js && node backend/src/database/seed.js",
    "deploy:docker": "docker compose up -d --build"
  },
  "devDependencies": {
    "qrcode": "^1.5.4"
  },
  "dependencies": {
    "pdfkit": "^0.19.1"
  }
}
